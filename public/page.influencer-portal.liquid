          <label for="prAddress1">Address Line 1 *</label>
          <input type="text" id="prAddress1" class="ip-auth-input" placeholder="123 Main Street" required>
        </div>
        
        <div class="ip-auth-group">
          <label for="prAddress2">Address Line 2 (optional)</label>
          <input type="text" id="prAddress2" class="ip-auth-input" placeholder="Apt 4B">
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="ip-auth-group">
            <label for="prCity">City *</label>
            <input type="text" id="prCity" class="ip-auth-input" placeholder="Mumbai" required>
          </div>
          <div class="ip-auth-group">
            <label for="prState">State *</label>
            <input type="text" id="prState" class="ip-auth-input" placeholder="Maharashtra" required>
          </div>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="ip-auth-group">
            <label for="prPincode">Pincode * (6 digits)</label>
            <input type="text" id="prPincode" class="ip-auth-input" placeholder="400001" maxlength="6" required>
          </div>
          <div class="ip-auth-group">
            <label for="prPhone">Phone * (10 digits)</label>
            <input type="text" id="prPhone" class="ip-auth-input" placeholder="9876543210" maxlength="10" required>
          </div>
        </div>
      </div>
      
      <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
        <button onclick="closeProductRequestModal()" style="flex: 1; padding: 0.8rem; background: transparent; border: 1px solid var(--border); color: var(--text); cursor: pointer; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 600;">Cancel</button>
        <button onclick="submitProductRequest()" style="flex: 1; padding: 0.8rem; background: var(--text); border: 1px solid var(--text); color: var(--bg); cursor: pointer; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 600;">Submit Request</button>
      </div>
    </div>
  `;
  
  document.body.appendChild(modal);
}

// Helper: Get month name
function getMonthName(monthNum) {
  const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
  return months[parseInt(monthNum) - 1];
}

// Override setTab to load enhanced shipments data
const originalSetTab = setTab;
setTab = function(tab) {
  originalSetTab(tab);
  if (tab === 'shipments') {
    loadMonthlyReelTarget();
    loadAssignedReels();
    loadMyProductRequests();
  }
};
</script>
</body>
