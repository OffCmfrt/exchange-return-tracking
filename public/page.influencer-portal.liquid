          <button class="ip-range-btn" data-lb-range="month:4" onclick="setLeaderboardRange('month:4')">April</button>
          <button class="ip-range-btn" data-lb-range="month:5" onclick="setLeaderboardRange('month:5')">May</button>
          <button class="ip-range-btn" data-lb-range="month:6" onclick="setLeaderboardRange('month:6')">June</button>
          <button class="ip-range-btn" data-lb-range="month:7" onclick="setLeaderboardRange('month:7')">July</button>
          <button class="ip-range-btn" data-lb-range="month:8" onclick="setLeaderboardRange('month:8')">August</button>
          <button class="ip-range-btn" data-lb-range="month:9" onclick="setLeaderboardRange('month:9')">September</button>
          <button class="ip-range-btn" data-lb-range="month:10" onclick="setLeaderboardRange('month:10')">October</button>
          <button class="ip-range-btn" data-lb-range="month:11" onclick="setLeaderboardRange('month:11')">November</button>
          <button class="ip-range-btn" data-lb-range="month:12" onclick="setLeaderboardRange('month:12')">December</button>
          <button class="ip-range-btn" data-lb-range="month:1" onclick="setLeaderboardRange('month:1')">January</button>
          <button class="ip-range-btn" data-lb-range="month:2" onclick="setLeaderboardRange('month:2')">February</button>
          <button class="ip-range-btn" data-lb-range="month:3" onclick="setLeaderboardRange('month:3')">March</button>
          <button class="ip-range-btn" data-lb-range="30d" onclick="setLeaderboardRange('30d')">Last 30 Days</button>
          <button class="ip-range-btn active" data-lb-range="all" onclick="setLeaderboardRange('all')">All Time</button>
        </div>
        <div style="overflow-x: auto; padding: 0 1.5rem 1.5rem;">
          <table class="ip-lb-table">
            <thead><tr><th>Rank</th><th>Name</th><th>Code</th></tr></thead>
