          <div style="height: 8px; background: var(--subtle); position: relative; overflow: hidden; margin-bottom: 0.75rem;">
            <div id="ipTargetProgressBar" style="height: 100%; width: 0%; background: linear-gradient(90deg, var(--success), #4ade80); transition: width 0.6s ease;"></div>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 0.7rem; color: var(--muted);">
            <span>Submitted: <strong id="ipSubmittedCount">0</strong></span>
