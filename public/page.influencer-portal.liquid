// Load monthly reel target
async function loadMonthlyReelTarget() {
  try {
    const now = new Date();
    const month = now.getMonth() + 1;
    const year = now.getFullYear();
    
    // Fetch actual target from API
    const targetRes = await fetch(`${PORTAL_API}/reel-targets/${token}?month=${month}&year=${year}`);
    const targetData = await targetRes.json();
    
    // Fetch shipments
    const shipmentsRes = await fetch(`${PORTAL_API}/shipments/${token}`);
    const shipmentsData = await shipmentsRes.json();
    
    if (!targetData.success || !shipmentsData.success) return;
    
    // Use actual target count from database (fallback to 3 if not set)
    const targetCount = targetData.progress?.targetCount || 3;
    const submittedCount = targetData.progress?.submittedCount || 0;
    const pendingCount = targetData.progress?.pendingCount || 0;
    const overdueCount = targetData.progress?.overdueCount || 0;
    const completionPercentage = targetData.progress?.completionPercentage || 0;
    
    // Update UI
    document.getElementById('ipTargetPeriod').textContent = `${getMonthName(month)} ${year}`;
    document.getElementById('ipTargetProgress').textContent = `${submittedCount}/${targetCount}`;
    document.getElementById('ipTargetPercentage').textContent = `${completionPercentage}%`;
    document.getElementById('ipTargetProgressBar').style.width = `${Math.min(completionPercentage, 100)}%`;
    document.getElementById('ipSubmittedCount').textContent = submittedCount;
    document.getElementById('ipPendingCount').textContent = pendingCount;
    document.getElementById('ipOverdueCount').textContent = overdueCount;
    
    // Color code percentage
    const pctEl = document.getElementById('ipTargetPercentage');
    if (completionPercentage >= 100) pctEl.style.color = 'var(--success)';
    else if (completionPercentage >= 50) pctEl.style.color = 'var(--warning)';
    else pctEl.style.color = 'var(--danger)';
  } catch (e) {
    console.error('Load monthly target error:', e);
  }
}

// Load assigned reels (enhanced version)
async function loadAssignedReels() {
  try {
    const res = await fetch(`${PORTAL_API}/shipments/${token}`);
    const data = await res.json();
    
    if (!data.success || !data.shipments || data.shipments.length === 0) {
      document.getElementById('ipAssignedReelsList').innerHTML = '<div class="ip-empty">No reels assigned yet</div>';
      document.getElementById('ipReelsCount').textContent = '0 reels';
      return;
    }
    
    const list = document.getElementById('ipAssignedReelsList');
    document.getElementById('ipReelsCount').textContent = `${data.shipments.length} reels`;
    
    const today = new Date().toISOString().split('T')[0];
    
    list.innerHTML = data.shipments.map(s => {
      const sent = new Date(s.sent_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
      const due = new Date(s.reel_due_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
      
      // Calculate days remaining
      const dueDate = new Date(s.reel_due_date);
      const todayDate = new Date(today);
      const daysRemaining = Math.ceil((dueDate - todayDate) / (1000 * 60 * 60 * 24));
      
      let statusBadge = '';
      let actionHtml = '';
      
      if (s.reel_status === 'received') {
        statusBadge = '<span class="ip-badge received">Submitted ✓</span>';
        actionHtml = s.reel_url ? `<a href="${portalEsc(s.reel_url)}" target="_blank" style="color: var(--text); font-size: 0.75rem;">View Reel →</a>` : '';
      } else if (s.reel_status === 'pending') {
        if (daysRemaining < 0) {
          statusBadge = '<span class="ip-badge overdue">Overdue</span>';
        } else {
          statusBadge = '<span class="ip-badge pending">Pending</span>';
        }
        actionHtml = `
          <input type="text" class="ip-ship-input" id="reel-${s.id}" placeholder="Paste Instagram Reel URL">
          <button class="ip-ship-submit" onclick="submitReelUrl(${s.id})">Submit</button>
        `;
      }
      
      const daysText = daysRemaining < 0 ? `${Math.abs(daysRemaining)} days overdue` : daysRemaining === 0 ? 'Due today' : `${daysRemaining} days remaining`;
      const daysColor = daysRemaining < 0 ? 'var(--danger)' : daysRemaining <= 3 ? 'var(--warning)' : 'var(--muted)';
      
      return `
        <div class="ip-ship-item" style="flex-direction: column; align-items: flex-start; gap: 0.75rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
            <div class="ip-ship-info">
              <div class="ip-ship-product">${portalEsc(s.product_title)}</div>
              <div class="ip-ship-dates">Sent: ${sent} · Due: ${due}</div>
            </div>
            ${statusBadge}
          </div>
          <div style="font-size: 0.7rem; color: ${daysColor}; font-weight: 600;">${daysText}</div>
          ${actionHtml ? `<div class="ip-ship-actions" style="width: 100%;">${actionHtml}</div>` : ''}
        </div>
      `;
    }).join('');
  } catch (e) {
    document.getElementById('ipAssignedReelsList').innerHTML = '<div class="ip-empty">Failed to load</div>';
  }
}

