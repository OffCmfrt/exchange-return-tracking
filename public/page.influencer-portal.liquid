// Submit product request
async function submitProductRequest() {
  const productTitle = document.getElementById('prProductTitle').value.trim();
  const sizeSelect = document.getElementById('prSize');
  const selectedSize = sizeSelect ? sizeSelect.value : '';
  const reason = document.getElementById('prReason').value.trim();
  const shippingFullName = document.getElementById('prFullName').value.trim();
  const shippingAddressLine1 = document.getElementById('prAddress1').value.trim();
  const shippingAddressLine2 = document.getElementById('prAddress2').value.trim();
  const shippingCity = document.getElementById('prCity').value.trim();
  const shippingState = document.getElementById('prState').value.trim();
  const shippingPincode = document.getElementById('prPincode').value.trim();
  const shippingPhone = document.getElementById('prPhone').value.trim();
  
  // Validation
  if (!productTitle || productTitle.length < 3) {
    alert('Product title must be at least 3 characters');
    return;
  }
  if (!selectedSize) {
    alert('Please select a size');
    return;
  }
  if (!reason || reason.length < 10) {
    alert('Please provide a detailed reason (min 10 characters)');
    return;
  }
  if (!shippingFullName) {
    alert('Please enter your full name');
    return;
  }
  if (!shippingAddressLine1) {
    alert('Please enter your address');
    return;
  }
  if (!shippingCity || !shippingState) {
    alert('Please enter your city and state');
    return;
  }
  if (!shippingPincode || shippingPincode.length !== 6) {
    alert('Invalid pincode (must be 6 digits)');
    return;
  }
  if (!shippingPhone || shippingPhone.length !== 10) {
    alert('Invalid phone number (must be 10 digits)');
    return;
  }
  
  try {
    const res = await fetch(`${PORTAL_API}/product-requests/${token}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        productTitle: selectedSize ? `${productTitle} (${selectedSize})` : productTitle,
        productImageUrl: null,
        reason,
        size: selectedSize,
        shippingFullName,
        shippingAddressLine1,
        shippingAddressLine2: shippingAddressLine2 || null,
        shippingCity,
        shippingState,
        shippingPincode,
        shippingPhone
      })
    });
    
    const data = await res.json();
    
    if (data.success) {
      alert('Product request submitted successfully! Admin will review and approve.');
      closeProductRequestModal();
      loadMyProductRequests();
    } else {
      alert(data.error || 'Failed to submit request');
    }
  } catch (e) {
    alert('Network error. Please try again.');
  }
}

