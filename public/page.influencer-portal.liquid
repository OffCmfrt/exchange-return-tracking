{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Influencer Performance Portal</title>
{% comment %}
  OFFCOMFRT — Influencer Performance Portal (Ultra-Premium Edition)
  Monochromatic B&W • Estimated Earnings • Date Range Filters • Micro-Animations
{% endcomment %}

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #000000;
  --surface: #0a0a0a;
  --surface-2: #121212;
  --border: #1f1f1f;
  --border-hover: #3a3a3a;
  --text: #ffffff;
  --muted: #555555;
  --subtle: #1a1a1a;
  --success: #22c55e;
  --danger: #ff3b3b;
  --transition: 0.22s cubic-bezier(0.4,0,0.2,1);
}

body, html { background: var(--bg); }

.ip-wrap {
  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ── LOADING ── */
.ip-loading {
  position: fixed; inset: 0;
  background: var(--bg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 1.5rem;
  z-index: 999;
  transition: opacity 0.5s ease;
}
.ip-loading.out { opacity: 0; pointer-events: none; }
.ip-spinner {
  width: 32px; height: 32px;
  border: 1.5px solid var(--border);
  border-top-color: var(--text);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}
.ip-loading p {
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--muted);
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── AUTH / LOGIN ── */
.ip-auth {
  position: fixed; inset: 0;
  background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  padding: 2rem;
  z-index: 800;
}
.ip-auth-card {
  background: var(--surface);
  border: 1px solid var(--border);
  width: 100%; max-width: 400px;
  padding: 3rem 2.5rem;
  text-align: center;
  animation: fadeUp 0.6s ease both;
}
.ip-auth-card h2 {
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 2rem;
}
.ip-auth-group {
  text-align: left;
  margin-bottom: 1.5rem;
}
.ip-auth-group label {
  display: block;
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--muted);
  margin-bottom: 0.6rem;
  font-weight: 600;
}
.ip-auth-input {
  width: 100%;
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 0.8rem 1rem;
  color: var(--text);
  font-family: inherit;
  font-size: 0.9rem;
  transition: border-color var(--transition);
  outline: none;
}
.ip-auth-input:focus { border-color: var(--text); }
.ip-auth-btn {
  width: 100%;
  background: var(--text);
  color: var(--bg);
  border: 1px solid var(--text);
  padding: 0.9rem;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  cursor: pointer;
  transition: all var(--transition);
}
.ip-auth-btn:hover { background: transparent; color: var(--text); }
.ip-auth-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.ip-auth-err {
  font-size: 0.72rem;
  color: var(--danger);
  margin-top: 1rem;
  display: none;
}
.ip-auth-err.show { display: block; }

/* ── MAIN ── */
.ip-main {
  max-width: 1000px;
  margin: 0 auto;
  padding: 4rem 2rem 6rem;
  display: none;
}
.ip-main.visible { display: block; }

/* ── HEADER ── */
.ip-header {
  text-align: center;
  margin-bottom: 4rem;
  animation: fadeUp 0.6s ease both;
}
.ip-header-brand {
  font-size: 0.6rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1.5rem;
}
.ip-header-name {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.5rem;
}
.ip-header h1 {
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 900;
  letter-spacing: -0.02em;
  line-height: 1;
  margin-bottom: 1.5rem;
  text-transform: uppercase;
}
.ip-code-badge {
  display: inline-block;
  border: 1px solid var(--border);
  padding: 0.5rem 1.25rem;
  font-size: 0.7rem;
  font-family: 'SF Mono', 'Fira Code', monospace;
  letter-spacing: 0.25em;
  color: var(--muted);
  background: var(--surface);
}

/* ── DATE RANGE ── */
.ip-range-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-bottom: 1.5rem;
  animation: fadeUp 0.6s 0.1s ease both;
  flex-wrap: wrap;
}
.ip-range-btn {
  padding: 0.6rem 1.5rem;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 600;
  font-family: inherit;
  background: transparent;
  border: 1px solid var(--border);
  color: var(--muted);
  cursor: pointer;
  transition: all var(--transition);
  margin-left: -1px;
  position: relative;
  z-index: 1;
}
.ip-range-btn:first-child { margin-left: 0; }
.ip-range-btn:hover { color: var(--text); border-color: var(--border-hover); z-index: 2; }
.ip-range-btn.active {
  background: var(--text);
  color: var(--bg);
  border-color: var(--text);
  z-index: 3;
}

/* ── CUSTOM DATE FILTER ── */
.ip-custom-date {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 3rem;
  animation: fadeUp 0.6s 0.12s ease both;
  flex-wrap: wrap;
}
.ip-custom-date.hidden { display: none; }
.ip-date-group {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.ip-date-group label {
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 600;
}
.ip-date-input {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 0.6rem 1rem;
  color: var(--text);
  font-family: inherit;
  font-size: 0.85rem;
  transition: border-color var(--transition);
  outline: none;
}
.ip-date-input:focus { border-color: var(--text); }
.ip-date-apply {
  padding: 0.6rem 1.5rem;
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 600;
  font-family: inherit;
  background: var(--text);
  border: 1px solid var(--text);
  color: var(--bg);
  cursor: pointer;
  transition: all var(--transition);
  align-self: flex-end;
}
.ip-date-apply:hover { background: transparent; color: var(--text); }
.ip-date-apply:disabled { opacity: 0.5; cursor: not-allowed; }

/* ── STATS GRID ── */
.ip-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  margin-bottom: 4rem;
  animation: fadeUp 0.6s 0.15s ease both;
}
.ip-stat-card {
  background: var(--surface);
  padding: 2.5rem 1.75rem;
  position: relative;
  overflow: hidden;
  transition: background var(--transition);
}
.ip-stat-card:hover { background: var(--surface-2); }
.ip-stat-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: var(--text);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
}
.ip-stat-card:hover::after { transform: scaleX(1); }
.ip-stat-label {
  font-size: 0.6rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1rem;
  font-weight: 600;
}
.ip-stat-value {
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.02em;
}
.ip-stat-value.earnings { color: var(--text); }
.ip-stat-sub {
  margin-top: 0.6rem;
  font-size: 0.6rem;
  color: var(--muted);
  letter-spacing: 0.1em;
}
.ip-stat-loading {
  display: inline-block;
  width: 40px; height: 8px;
  background: var(--subtle);
  border-radius: 2px;
  animation: shimmer 1.2s ease infinite;
}
@keyframes shimmer {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

/* ── FEED ── */
.ip-feed {
  animation: fadeUp 0.6s 0.25s ease both;
}
.ip-feed-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border);
}
.ip-feed-title {
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 600;
}
.ip-feed-count {
  font-size: 0.65rem;
  color: var(--muted);
  letter-spacing: 0.1em;
}
.ip-feed-list {
  border: 1px solid var(--border);
}
.ip-feed-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem 1.5rem;
  border-bottom: 1px solid var(--border);
  transition: background var(--transition);
  animation: fadeUp 0.3s ease both;
}
.ip-feed-item:last-child { border-bottom: none; }
.ip-feed-item:hover { background: var(--surface); }
.ip-order-name {
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 0.02em;
}
.ip-order-date {
  font-size: 0.7rem;
  color: var(--muted);
  margin-top: 0.2rem;
  letter-spacing: 0.05em;
}
.ip-order-total {
  font-weight: 700;
  font-size: 0.9rem;
  color: var(--success);
}
.ip-feed-empty {
  text-align: center;
  padding: 4rem 2rem;
  color: var(--muted);
}
.ip-feed-empty h3 {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--text);
  margin-bottom: 0.5rem;
}
.ip-feed-empty p { font-size: 0.75rem; }

/* ── FOOTER ── */
.ip-footer {
  text-align: center;
  margin-top: 5rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
  font-size: 0.62rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  animation: fadeUp 0.6s 0.3s ease both;
}

/* ── PORTAL SECTIONS ── */
.ip-section {
  margin-top: 2.5rem;
  border: 1px solid var(--border);
  background: var(--surface);
  animation: fadeUp 0.6s ease both;
}
.ip-section-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 1rem 1.5rem;
  border-bottom: 1px solid var(--border);
}
.ip-section-header h3 {
  font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
}
.ip-ship-list { padding: 0; }
.ip-ship-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 1rem 1.5rem;
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap; gap: 0.5rem;
}
.ip-ship-item:last-child { border-bottom: none; }
.ip-ship-info { flex: 1; }
.ip-ship-product { font-weight: 600; font-size: 0.85rem; }
.ip-ship-dates { font-size: 0.7rem; color: var(--muted); margin-top: 0.25rem; }
.ip-ship-actions { display: flex; gap: 0.5rem; align-items: center; }
.ip-ship-input {
  padding: 0.4rem 0.6rem; font-size: 0.7rem; background: var(--surface-2);
  border: 1px solid var(--border); color: var(--text); width: 180px;
}
.ip-ship-submit {
  padding: 0.4rem 0.7rem; font-size: 0.65rem; background: var(--text);
  border: none; color: var(--bg); cursor: pointer; letter-spacing: 0.05em;
  text-transform: uppercase; font-weight: 600;
}
.ip-badge {
  display: inline-block; padding: 0.2rem 0.5rem; font-size: 0.6rem;
  letter-spacing: 0.05em; text-transform: uppercase; font-weight: 600;
}
.ip-badge.pending { background: #f59e0b; color: #000; }
.ip-badge.received { background: #22c55e; color: #fff; }
.ip-badge.overdue { background: #ff3b3b; color: #fff; }
.ip-badge.paid { background: #22c55e; color: #fff; }
.ip-badge.unpaid { background: #555; color: #fff; }

.ip-payout-table { width: 100%; border-collapse: collapse; font-size: 0.75rem; }
.ip-payout-table th {
  text-align: left; padding: 0.75rem 1.5rem; font-size: 0.6rem;
  letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted);
  border-bottom: 1px solid var(--border); background: var(--surface-2);
}
.ip-payout-table td { padding: 0.7rem 1.5rem; border-bottom: 1px solid var(--border); }
.ip-payout-table tr:last-child td { border-bottom: none; }

.ip-lb-table { width: 100%; border-collapse: collapse; }
.ip-lb-table th {
  text-align: left; padding: 0.75rem 1.5rem; font-size: 0.6rem;
  letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted);
  border-bottom: 1px solid var(--border); background: var(--surface-2);
}
.ip-lb-table td { padding: 0.75rem 1.5rem; border-bottom: 1px solid var(--border); font-size: 0.8rem; }
.ip-lb-table tr:last-child td { border-bottom: none; }
.ip-lb-table tr.highlight { background: var(--surface-2); }
.ip-lb-rank {
  display: inline-flex; align-items: center; justify-content: center;
  width: 22px; height: 22px; border-radius: 50%;
  background: var(--subtle); font-size: 0.65rem; font-weight: 700;
}
.ip-lb-rank.top1 { background: var(--text); color: var(--bg); }
.ip-empty { text-align: center; padding: 2rem; color: var(--muted); font-size: 0.75rem; }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

.hidden { display: none !important; }

/* ── TAB BAR ── */
.ip-tab-bar {
  display: flex; gap: 0;
  margin-bottom: 2.5rem;
  border-bottom: 1px solid var(--border);
  animation: fadeUp 0.6s 0.08s ease both;
}
.ip-tab-btn {
  flex: 1; max-width: 220px;
  padding: 1rem 1.25rem;
  background: transparent; border: none;
  border-bottom: 2px solid transparent;
  color: var(--muted);
  font-family: inherit; font-size: 0.68rem;
  letter-spacing: 0.25em; text-transform: uppercase;
  font-weight: 700; cursor: pointer;
  transition: all var(--transition);
  margin-bottom: -1px;
}
.ip-tab-btn:hover { color: var(--text); }
.ip-tab-btn.active { color: var(--text); border-bottom-color: var(--text); }

/* ── PENDING BANNER ── */
.ip-pending-banner {
  background: linear-gradient(135deg, rgba(245,158,11,0.12), rgba(245,158,11,0.04));
  border: 1px solid rgba(245,158,11,0.4);
  border-left: 3px solid #f59e0b;
  padding: 1.25rem 1.5rem;
  margin-bottom: 2rem;
  animation: fadeUp 0.6s 0.08s ease both;
}
.ip-pending-banner.hidden { display: none; }
.ip-pending-banner-title {
  font-size: 0.7rem; letter-spacing: 0.25em;
  text-transform: uppercase; font-weight: 800;
  color: #f59e0b; margin-bottom: 0.5rem;
}
.ip-pending-banner p { font-size: 0.88rem; color: rgba(245,158,11,0.8); line-height: 1.55; }

/* ── PAYOUTS VIEW ── */
.ip-payout-summary {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--border);
  border: 1px solid var(--border);
  margin-bottom: 2rem;
  animation: fadeUp 0.6s 0.1s ease both;
}
.ip-payout-summary-cell {
  background: var(--surface);
  padding: 1.25rem 1.5rem;
}
.ip-payout-summary-cell .lbl {
  font-size: 0.6rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--muted); font-weight: 700;
  margin-bottom: 0.4rem;
}
.ip-payout-summary-cell .val {
  font-size: 1.4rem; font-weight: 800; color: var(--text);
}

.ip-ledger {
  animation: fadeUp 0.6s 0.12s ease both;
}
.ip-ledger-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 1rem;
}
.ip-ledger-title {
  font-size: 0.7rem; letter-spacing: 0.25em;
  text-transform: uppercase; font-weight: 700;
}
.ip-ledger-count {
  font-size: 0.75rem; color: var(--muted);
}
.ip-ledger-list { display: flex; flex-direction: column; }
.ip-ledger-item {
  border: 1px solid var(--border);
  padding: 1rem 1.25rem;
  margin-bottom: 0.5rem;
  background: var(--surface);
  display: flex; justify-content: space-between; align-items: center;
  transition: all var(--transition);
}
.ip-ledger-item:hover { border-color: var(--border-hover); }
.ip-ledger-item .left { flex: 1; }
.ip-ledger-item .period {
  font-size: 0.85rem; font-weight: 600; margin-bottom: 0.25rem;
}
.ip-ledger-item .meta {
  font-size: 0.75rem; color: var(--muted);
}
.ip-ledger-item .right { text-align: right; }
.ip-ledger-item .amt {
  font-size: 1.05rem; font-weight: 700;
}
.ip-ledger-item .badge {
  display: inline-block; padding: 2px 8px;
  font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; border-radius: 999px; margin-top: 0.3rem;
}
.ip-ledger-item .badge.paid { background: rgba(34,197,94,0.15); color: var(--success); }
.ip-ledger-item .badge.pending { background: rgba(245,158,11,0.15); color: #f59e0b; }
.ip-ledger-item .badge.cancelled { background: rgba(255,59,59,0.12); color: var(--danger); }
.ip-ledger-empty {
  text-align: center; padding: 3rem 1rem;
  color: var(--muted);
}
.ip-ledger-empty h3 { font-size: 1rem; margin-bottom: 0.5rem; color: var(--text); }
.ip-ledger-empty p { font-size: 0.85rem; }

@media (max-width: 700px) {
  .ip-stats-grid { grid-template-columns: 1fr 1fr; }
  .ip-payout-summary { grid-template-columns: 1fr; }
  .ip-tab-btn { font-size: 0.55rem; padding: 0.75rem 0.5rem; letter-spacing: 0.15em; }
}
@media (max-width: 420px) {
  .ip-stats-grid { grid-template-columns: 1fr; }
  .ip-tab-btn { font-size: 0.5rem; padding: 0.65rem 0.4rem; letter-spacing: 0.1em; }
}
</style>
</head>
<body>
<div class="ip-wrap">

  <!-- Loading -->
  <div id="ipLoading" class="ip-loading">
    <div class="ip-spinner"></div>
    <p>Syncing Performance</p>
  </div>

  <!-- Error -->
  <div id="ipError" class="ip-error" style="position: fixed; inset: 0; background: var(--bg); display: none; flex-direction: column; align-items: center; justify-content: center; gap: 1rem;">
    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <h2 style="font-size: 0.9rem; font-weight: 600; color: var(--text); letter-spacing: 0.05em;">Invalid Access Link</h2>
    <p style="font-size: 0.78rem; color: var(--muted);">Please contact your manager for a new portal link.</p>
  </div>

  <!-- Auth/Login -->
  <div id="ipAuth" class="ip-auth hidden">
    <div class="ip-auth-card">
      <p class="ip-header-brand" style="margin-bottom:0.5rem;">Access Verification</p>
      <h2 id="ipAuthWelcome">Ambassador Portal</h2>
      <div class="ip-auth-group">
        <label for="ipPhone">Registered Phone Number</label>
        <input type="tel" id="ipPhone" class="ip-auth-input" placeholder="e.g. 9876543210" onkeypress="if(event.key==='Enter') handleLogin()">
      </div>
      <button id="ipLoginBtn" class="ip-auth-btn" onclick="handleLogin()">Sign In</button>
      <p id="ipAuthErr" class="ip-auth-err">Incorrect phone number. Please try again.</p>
    </div>
  </div>

  <!-- Portal -->
  <div id="ipMain" class="ip-main">

    <!-- Header -->
    <header class="ip-header">
      <p class="ip-header-brand">Offcomfrt · Ambassador Portal</p>
      <p class="ip-header-name" id="ipName">—</p>
      <h1>Performance<br>Dashboard</h1>
      <div class="ip-code-badge" id="ipCodeBadge">CODE: ——</div>
    </header>

    <!-- Pending Banner -->
    <div id="ipPendingBanner" class="ip-pending-banner hidden">
      <div class="ip-pending-banner-title">Application Under Review</div>
      <p>Thanks for signing up! Your ambassador application is being reviewed by our team. Your referral code will go live at checkout once approved — usually within 1–2 business days. You can still explore this portal in the meantime.</p>
    </div>

    <!-- Tab Bar -->
    <div class="ip-tab-bar">
      <button class="ip-tab-btn active" data-tab="performance" onclick="setTab('performance')">Performance</button>
