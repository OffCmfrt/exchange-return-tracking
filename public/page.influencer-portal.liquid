            <span class="ip-badge ${s.reel_status}">${s.reel_status}</span>
            ${actionHtml}
          </div>
        </div>
      `;
    }).join('');
  } catch (e) {
    document.getElementById('ipShipmentsList').innerHTML = '<div class="ip-empty">Failed to load</div>';
  }
}

async function submitReelUrl(shipmentId) {
  const input = document.getElementById(`reel-${shipmentId}`);
  const reelUrl = input.value.trim();
  if (!reelUrl) { alert('Please paste a URL'); return; }
  try {
    const res = await fetch(`${PORTAL_API}/shipments/${token}/${shipmentId}`, {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ reelUrl })
    });
    const data = await res.json();
    if (data.success) {
      alert('Reel submitted!');
      loadPortalShipments();
    } else { alert(data.error || 'Failed'); }
  } catch (e) { alert('Network error'); }
}

async function loadPortalLeaderboard() {
  try {
    let qp = `?range=${leaderboardRange}&limit=10`;
    
    // Handle monthly ranges
    if (leaderboardRange.startsWith('month:')) {
      const month = leaderboardRange.split(':')[1];
      const now = new Date();
      const currentMonth = now.getMonth() + 1;
      const currentYear = now.getFullYear();
      
      // Calculate the year for the selected month
      let year = currentYear;
      if (parseInt(month) > currentMonth) {
        year = currentYear - 1;
      }
      
      const startDate = `${year}-${month.padStart(2, '0')}-01`;
      const endDate = `${year}-${month.padStart(2, '0')}-31`;
      
      qp = `?range=custom&startDate=${encodeURIComponent(startDate)}&endDate=${encodeURIComponent(endDate)}&limit=10`;
    }
    
    const res = await fetch(`${PORTAL_API}/leaderboard/${token}${qp}`);
    const data = await res.json();
    if (!data.success || !data.leaderboard || data.leaderboard.length === 0) {
      document.getElementById('ipLeaderboardBody').innerHTML = '<tr><td colspan="3" class="ip-empty">No data</td></tr>';
      return;
    }
    document.getElementById('ipLeaderboardBody').innerHTML = data.leaderboard.map(r => `
      <tr class="${r.current_user ? 'highlight' : ''}">
        <td><span class="ip-lb-rank ${r.rank === 1 ? 'top1' : ''}">${r.rank}</span></td>
        <td style="font-weight: 600;">${portalEsc(r.name)} ${r.current_user ? '(You)' : ''}</td>
        <td style="color: var(--muted); font-size: 0.7rem;">${portalEsc(r.referral_code)}</td>
      </tr>
    `).join('');
  } catch (e) {
    document.getElementById('ipLeaderboardBody').innerHTML = '<tr><td colspan="3" class="ip-empty">Failed to load</td></tr>';
  }
}

function setLeaderboardRange(range) {
  leaderboardRange = range;
  
  // Update active button
  document.querySelectorAll('[data-lb-range]').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.lbRange === range);
  });
  
  // Reload leaderboard with new range
  loadPortalLeaderboard();
}

