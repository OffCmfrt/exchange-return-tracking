// ==================== SHIPPING ADDRESS SETTINGS ====================

let _cachedAddressData = null;

async function loadShippingAddress() {
  const display = document.getElementById('ipAddressDisplay');
  const editBtn = document.getElementById('ipEditAddressBtn');
  display.innerHTML = '<div style="color: var(--muted); font-size: 0.75rem;">Loading address...</div>';
  try {
    const res = await fetch(`${PORTAL_API}/shipping-address/${token}`);
    const data = await res.json();
    if (!data.success) { display.innerHTML = '<div style="color: var(--muted);">Failed to load address.</div>'; return; }
    _cachedAddressData = data.shippingAddress;
    renderAddressDisplay(data.shippingAddress);
    editBtn.style.display = '';
  } catch (err) {
    display.innerHTML = '<div style="color: var(--muted);">Connection error.</div>';
  }
}

function renderAddressDisplay(addr) {
  const display = document.getElementById('ipAddressDisplay');
  const hasAddress = addr.shipping_address || addr.shipping_city || addr.shipping_state || addr.shipping_pin;
  if (!hasAddress) {
    display.innerHTML = `
      <div style="text-align: center; padding: 2rem; color: var(--muted);">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 0.75rem; opacity: 0.5;">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <p style="font-size: 0.8rem;">No shipping address saved yet.</p>
        <button class="ip-btn ip-btn-small" onclick="toggleAddressEdit(true)" style="margin-top: 1rem;">Add Address</button>
      </div>`;
    return;
  }
  const typeLabel = addr.address_type === 'office' ? '\ud83c\udfe2 Office' : '\ud83c\udfe0 Home';
  display.innerHTML = `
    <div style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--muted); margin-bottom: 0.75rem;">${typeLabel}</div>
    <div style="font-size: 0.85rem; line-height: 1.8; color: var(--text);">
      <div style="font-weight: 600;">${addr.shipping_address || ''}</div>
      ${addr.shipping_landmark ? `<div style="color: var(--muted); font-size: 0.8rem;">Near: ${addr.shipping_landmark}</div>` : ''}
      <div>${addr.shipping_city || ''}${addr.shipping_city && addr.shipping_state ? ', ' : ''}${addr.shipping_state || ''} ${addr.shipping_pin || ''}</div>
    </div>`;
}

function toggleAddressEdit(show) {
  const form = document.getElementById('ipAddressEditForm');
  const display = document.getElementById('ipAddressDisplay');
  const editBtn = document.getElementById('ipEditAddressBtn');
  if (show) {
    // Populate form with current data
    const addr = _cachedAddressData || {};
    document.getElementById('ipAddressType').value = addr.address_type || 'home';
    document.getElementById('ipShipAddress').value = addr.shipping_address || '';
    document.getElementById('ipShipLandmark').value = addr.shipping_landmark || '';
    document.getElementById('ipShipCity').value = addr.shipping_city || '';
    document.getElementById('ipShipState').value = addr.shipping_state || '';
    document.getElementById('ipShipPincode').value = addr.shipping_pin || '';
    form.style.display = '';
    editBtn.style.display = 'none';
  } else {
    form.style.display = 'none';
    editBtn.style.display = '';
  }
}

async function saveShippingAddress() {
  const btn = document.getElementById('ipSaveAddressBtn');
  const shippingAddress = document.getElementById('ipShipAddress').value.trim();
  const shippingLandmark = document.getElementById('ipShipLandmark').value.trim();
  const shippingCity = document.getElementById('ipShipCity').value.trim();
  const shippingState = document.getElementById('ipShipState').value.trim();
  const shippingPin = document.getElementById('ipShipPincode').value.trim();
  const addressType = document.getElementById('ipAddressType').value;

  if (!shippingAddress || !shippingCity || !shippingState || !shippingPin) {
    showToast('Please fill all required address fields', true);
    return;
  }
  if (!/^\d{6}$/.test(shippingPin)) {
    showToast('Pincode must be 6 digits', true);
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Saving...';
  try {
    const res = await fetch(`${PORTAL_API}/shipping-address/${token}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ shippingAddress, shippingLandmark, shippingCity, shippingState, shippingPin, addressType })
    });
    const data = await res.json();
    if (data.success) {
      showToast('Shipping address updated \u2713');
      toggleAddressEdit(false);
      await loadShippingAddress();
    } else {
      showToast(data.error || 'Failed to save address', true);
    }
  } catch (err) {
    showToast('Connection error', true);
  }
  btn.disabled = false;
  btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Save Address';
}

// ==================== MESSAGING SYSTEM ====================

// Message state
let messagePollingInterval = null;
let currentAuthToken = token;

// Load messages
async function loadMessages() {
  try {
    const authToken = currentAuthToken || token;
    if (!authToken) return;

    const response = await fetch(`https://exchange-return-tracking.onrender.com/api/influencer/messages?token=${authToken}`);
    const data = await response.json();
    
    if (data.success) {
      renderMessages(data.messages);
      updateUnreadBadge();
    }
  } catch (error) {
    console.error('Failed to load messages:', error);
  }
}

// Render messages
function renderMessages(messages) {
  const container = document.getElementById('ipMessagesList');
  
  if (!messages || messages.length === 0) {
    container.innerHTML = `
      <div class="ip-empty">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 1rem;">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <p>No messages yet</p>
      </div>
    `;
    return;
  }

  container.innerHTML = messages.map(msg => {
    const isIncoming = msg.sender_type === 'admin';
    const isBroadcast = msg.is_broadcast;
    const isUnread = !msg.is_read && isIncoming;
    const timeAgo = getTimeAgo(msg.created_at);
    
    return `
      <div class="ip-message-item ${isUnread ? 'unread' : ''} ${isBroadcast ? 'broadcast' : ''}" onclick="markAsRead('${msg.message_id}')">
        <div class="ip-message-meta">
          <div class="ip-message-sender">
            ${isBroadcast ? '<span class="ip-message-badge">Broadcast</span>' : ''}
            ${isIncoming ? 'Admin' : 'You'}
          </div>
          <span class="ip-message-time">${timeAgo}</span>
        </div>
        ${msg.subject ? `<div class="ip-message-subject">${escapeHtml(msg.subject)}</div>` : ''}
        <div class="ip-message-content">${escapeHtml(msg.content)}</div>
      </div>
    `;
  }).join('');
}

// Open compose message
function openComposeMessage() {
  document.getElementById('ipComposeArea').classList.remove('hidden');
}

// Close compose message
function closeComposeMessage() {
  document.getElementById('ipComposeArea').classList.add('hidden');
  document.getElementById('ipMessageSubject').value = '';
  document.getElementById('ipMessageContent').value = '';
}

// Send message to admin
async function sendInfluencerMessage() {
  const subject = document.getElementById('ipMessageSubject').value;
  const content = document.getElementById('ipMessageContent').value;

  if (!content.trim()) {
    alert('Please enter a message');
    return;
  }

  try {
    const authToken = currentAuthToken || token;
    
    const response = await fetch('https://exchange-return-tracking.onrender.com/api/influencer/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        token: authToken,
        subject: subject || null,
        content
      })
    });

    const data = await response.json();
    
    if (data.success) {
      closeComposeMessage();
      loadMessages();
      showToast('Message sent');
    } else {
      showToast(data.error || 'Failed to send message', true);
    }
  } catch (error) {
    console.error('Failed to send message:', error);
    showToast('Failed to send message', true);
  }
}

// Mark message as read
async function markAsRead(messageId) {
  try {
    const authToken = currentAuthToken || token;
    
    await fetch(`https://exchange-return-tracking.onrender.com/api/influencer/messages/${messageId}/read`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: authToken })
    });
    
    // Refresh messages
    loadMessages();
  } catch (error) {
    console.error('Failed to mark as read:', error);
  }
}

// Update unread badge
async function updateUnreadBadge() {
  try {
    const authToken = currentAuthToken || token;
    if (!authToken) return;

    const response = await fetch(`https://exchange-return-tracking.onrender.com/api/influencer/messages/unread-count?token=${authToken}`);
    const data = await response.json();
    
    if (data.success && data.count > 0) {
      const badge = document.getElementById('ipUnreadBadge');
      badge.textContent = data.count > 99 ? '99+' : data.count;
      badge.classList.remove('hidden');
    } else {
      document.getElementById('ipUnreadBadge')?.classList.add('hidden');
    }
  } catch (error) {
    console.error('Failed to get unread count:', error);
  }
}

// Start message polling
function startMessagePolling() {
  if (messagePollingInterval) {
    clearInterval(messagePollingInterval);
  }
  
  messagePollingInterval = setInterval(() => {
    loadMessages();
  }, 30000); // 30 seconds
}

// Stop message polling
function stopMessagePolling() {
  if (messagePollingInterval) {
    clearInterval(messagePollingInterval);
    messagePollingInterval = null;
  }
}

// Helper: Time ago
function getTimeAgo(dateString) {
  const now = new Date();
  const date = new Date(dateString);
  const seconds = Math.floor((now - date) / 1000);
  
  if (seconds < 60) return 'Just now';
  if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;
  if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;
  return `${Math.floor(seconds / 86400)}d ago`;
}

// Helper: Escape HTML
function escapeHtml(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}
