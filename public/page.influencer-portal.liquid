function closeBrowseInventoryModal() {
  const modal = document.getElementById('ipBrowseInventoryModal');
  if (modal) modal.remove();
}

async function searchInventoryProducts(page = 1) {
  const search = document.getElementById('ipInventorySearch').value;
  const grid = document.getElementById('ipInventoryGrid');
  const paginationEl = document.getElementById('ipInventoryPagination');
  
  ipInventoryPage = page;
  
  try {
    grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 3rem; color: var(--muted);"><div style="width: 32px; height: 32px; border: 2px solid var(--muted); border-top-color: var(--text); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 1rem;"></div><p style="font-size: 0.8rem;">Searching available products...</p></div>';
    if (paginationEl) paginationEl.style.display = 'none';
    
    const res = await fetch(`${API_BASE}/influencer/${token}/shopify-products?search=${encodeURIComponent(search)}&limit=${IP_PRODUCTS_PER_PAGE}&page=${page}`);
    const data = await res.json();
    
    if (!data.success || !data.products || data.products.length === 0) {
      grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 3rem; color: var(--muted);"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="margin-bottom: 1rem; opacity: 0.3;"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg><p style="font-size: 0.8rem;">No available products found</p><p style="font-size: 0.7rem; margin-top: 0.5rem;">All products are out of stock or no matches</p></div>';
      return;
    }
    
    grid.innerHTML = data.products.map(p => {
      const imageUrl = p.images[0]?.src || '';
      const price = p.variants[0]?.price || '0';
      const title = p.title;
      const productId = p.id;
      const totalStock = p.totalStock || 0;
      const variantCount = p.variants.length;
      const sizesHtml = p.variants.map(v => 
        `<span style="display: inline-block; padding: 0.15rem 0.4rem; font-size: 0.6rem; border: 1px solid var(--border); margin: 0.1rem; background: var(--bg); font-weight: 500;">${v.title}</span>`
      ).join('');
      
      return `
        <div style="border: 1px solid var(--border); background: var(--bg); overflow: hidden; display: flex; flex-direction: column; transition: border-color 0.2s, transform 0.2s;" onmouseenter="this.style.borderColor='var(--text)';this.style.transform='translateY(-2px)'" onmouseleave="this.style.borderColor='var(--border)';this.style.transform='translateY(0)'">
          <div style="position: relative;">
            ${imageUrl ? `<img src="${imageUrl}" style="width: 100%; height: 200px; object-fit: contain; background: var(--subtle);">` : '<div style="width: 100%; height: 200px; background: var(--subtle); display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 0.7rem;"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></div>'}
          </div>
          <div style="padding: 0.75rem; flex: 1; display: flex; flex-direction: column;">
            <div style="font-weight: 600; font-size: 0.75rem; margin-bottom: 0.3rem; line-height: 1.3; flex: 1;">${portalEsc(title)}</div>
            <div style="font-size: 0.85rem; font-weight: 700; margin-bottom: 0.5rem;">&#8377;${price}</div>
            <div style="margin-bottom: 0.6rem;">
              <div style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 0.3rem; font-weight: 600;">Available Sizes</div>
              <div style="display: flex; flex-wrap: wrap; gap: 0;">${sizesHtml}</div>
            </div>
            <button onclick='requestProductFromInventory(${JSON.stringify({id: productId, title: title, imageUrl: imageUrl, variants: p.variants}).replace(/'/g, "&apos;")})' style="width: 100%; padding: 0.5rem; background: var(--text); border: 1px solid var(--text); color: var(--bg); cursor: pointer; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; margin-top: auto; transition: opacity 0.2s;" onmouseenter="this.style.opacity='0.85'" onmouseleave="this.style.opacity='1'">
              Request This Product
            </button>
          </div>
        </div>
      `;
    }).join('');
    
    // Update pagination controls
    if (data.pagination && paginationEl) {
      const { totalProducts, totalPages, hasNextPage, hasPrevPage } = data.pagination;
      paginationEl.style.display = 'flex';
      document.getElementById('ipPageInfo').textContent = `Page ${page} of ${totalPages}`;
      document.getElementById('ipTotalProducts').textContent = `${totalProducts} products available`;
      document.getElementById('ipPrevPage').disabled = !hasPrevPage;
      document.getElementById('ipPrevPage').style.opacity = hasPrevPage ? '1' : '0.4';
      document.getElementById('ipNextPage').disabled = !hasNextPage;
      document.getElementById('ipNextPage').style.opacity = hasNextPage ? '1' : '0.4';
    }
  } catch (e) {
    console.error('Search inventory error:', e);
    grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 3rem; color: var(--danger, #ef4444);"><p style="font-size: 0.8rem;">Failed to load products</p><p style="font-size: 0.7rem; margin-top: 0.5rem; color: var(--muted);">Please check your connection</p><button onclick="searchInventoryProducts(1)" style="margin-top: 1rem; padding: 0.5rem 1.5rem; background: var(--text); border: 1px solid var(--text); color: var(--bg); cursor: pointer; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">Retry</button></div>';
  }
}

function requestProductFromInventory(product) {
  // Close inventory modal
  closeBrowseInventoryModal();
  
  // Open product request modal with pre-filled data and size selection
  setTimeout(() => {
    openProductRequestModalWithProduct(product.title, product.imageUrl, product.variants || []);
  }, 200);
}

