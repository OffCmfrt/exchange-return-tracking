 <div id="iaAddModal" class="ia-modal-overlay" onclick="handleOverlayClick(event, 'iaAddModal')">
 <div class="ia-modal-box">
 <div class="ia-modal-header">
 <span class="ia-modal-title">Add New Ambassador</span>
 <button class="ia-modal-close" onclick="closeModal('iaAddModal')">&times;</button>
 </div>
 <div class="ia-form-group">
 <label for="addName">Full Name</label>
 <input type="text" id="addName" class="ia-input" placeholder="e.g. Rahul Sharma">
 </div>
 <div class="ia-form-group">
 <label for="addPhone">Phone Number (For Portal Login)</label>
 <input type="text" id="addPhone" class="ia-input" placeholder="e.g. 9876543210">
 </div>
 <div class="ia-form-row">
 <div class="ia-form-group">
 <label for="addCode">Shopify Discount Code</label>
 <input type="text" id="addCode" class="ia-input" placeholder="e.g. RAHUL10" style="text-transform:uppercase;">
 </div>
 <div class="ia-form-group">
 <label for="addCommission">Commission Rate (%)</label>
 <input type="number" id="addCommission" class="ia-input" placeholder="7" min="0" max="100" step="0.5" value="7">
 <p class="ia-form-hint">What they actually earn (admin only)</p>
 </div>
 <div class="ia-form-group">
 <label for="addDisplayedCommission">Displayed Commission (%)</label>
 <input type="number" id="addDisplayedCommission" class="ia-input" placeholder="7" min="0" max="100" step="0.5" value="7">
 <p class="ia-form-hint">What influencers see in their portal</p>
 </div>
 </div>
 <div class="ia-form-row">
 <div class="ia-form-group">
 <label for="addDiscountValue">Customer Discount (%)</label>
 <input type="number" id="addDiscountValue" class="ia-input" placeholder="10" min="0" max="100" step="0.5" value="10">
 <p class="ia-form-hint">Discount customers get (default: same as commission)</p>
 </div>
 <div class="ia-form-group">
 <label for="addUsageLimit">Usage Limit</label>
 <input type="number" id="addUsageLimit" class="ia-input" placeholder="Leave blank = unlimited" min="1">
 <p class="ia-form-hint">Max uses (blank = unlimited)</p>
 </div>
 </div>
 <p id="addError" class="ia-modal-error">Failed to add. Code might already exist.</p>
 <div class="ia-modal-actions">
 <button class="ia-btn ia-btn-ghost" onclick="closeModal('iaAddModal')">Cancel</button>
 <button class="ia-btn ia-btn-primary" id="addSubmitBtn" onclick="submitAdd()">Create Link</button>
 </div>
 </div>
 </div>
<div id="iaStatsModal" class="ia-modal-overlay" onclick="handleOverlayClick(event, 'iaStatsModal')">
 <div class="ia-modal-box" style="max-width: 900px; max-height: 90vh; overflow-y: auto;">
 <div class="ia-modal-header">
 <span class="ia-modal-title" id="statsModalTitle">Ambassador Performance</span>
 <button class="ia-modal-close" onclick="closeModal('iaStatsModal')">&times;</button>
 </div>
<div class="ia-stats-filter">
 <div class="ia-filter-row">
 <div class="ia-filter-group">
 <span class="ia-filter-label">Date Range</span>
 <div class="ia-range-buttons">
 <button class="ia-range-btn" data-range="30d" onclick="setStatsRange('30d')">30 Days</button>
 <button class="ia-range-btn" data-range="90d" onclick="setStatsRange('90d')">90 Days</button>
 <button class="ia-range-btn active" data-range="all" onclick="setStatsRange('all')">All Time</button>
 <button class="ia-range-btn" data-range="custom" onclick="toggleCustomDate()">Custom</button>
 </div>
 </div>
 </div>
 <div class="ia-filter-row" id="customDateRow" style="display: none;">
 <div class="ia-filter-group">
 <label for="statsStartDate">Start Date</label>
 <input type="date" id="statsStartDate" class="ia-input">
 </div>
 <div class="ia-filter-group">
 <label for="statsEndDate">End Date</label>
 <input type="date" id="statsEndDate" class="ia-input">
 </div>
 <div class="ia-filter-group" style="display: flex; align-items: flex-end;">
 <button class="ia-btn ia-btn-primary" onclick="applyCustomDate()">Apply</button>
 </div>
 </div>
 </div>
<div class="ia-tabs">
 <button class="ia-tab-btn active" data-tab="overview" onclick="switchTab('overview', this)">Overview</button>
 <button class="ia-tab-btn" data-tab="shipments" onclick="switchTab('shipments', this)">Shipments & Reels</button>
 <button class="ia-tab-btn" data-tab="payouts" onclick="switchTab('payouts', this)">Payouts</button>
 </div>
<div class="ia-tab-content active" id="tab-overview">
<div class="ia-stats-grid" id="statsGrid">
 <div class="ia-stat-box">
 <div class="ia-stat-box-label">Total Revenue</div>
 <div class="ia-stat-box-value" id="statTotalRevenue">—</div>
 </div>
 <div class="ia-stat-box">
 <div class="ia-stat-box-label">Total Orders</div>
 <div class="ia-stat-box-value" id="statTotalOrders">—</div>
 </div>
 <div class="ia-stat-box">
 <div class="ia-stat-box-label">Avg. Order Value</div>
 <div class="ia-stat-box-value" id="statAov">—</div>
 </div>
 <div class="ia-stat-box highlight">
 <div class="ia-stat-box-label">Estimated Earnings</div>
 <div class="ia-stat-box-value" id="statEarnings">—</div>
 <div class="ia-stat-box-sub" id="statCommissionRate">—</div>
 </div>
 </div>
<div class="ia-monthly-bars" id="monthlyBars"></div>
<div class="ia-conversions-section">
 <div class="ia-section-header" style="margin-top: 2rem;">
 <span class="ia-section-title">Recent Conversions</span>
 <span id="statsConversionsCount" style="font-size: 0.65rem; color: var(--muted);"></span>
 </div>
 <div class="ia-conversions-list" id="statsConversionsList">
 <div class="ia-conversion-empty">Select a date range to view conversions</div>
 </div>
 </div>
 </div>
<div class="ia-tab-content" id="tab-shipments">
 <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
 <span style="font-size: 0.75rem; color: var(--muted);">Product shipments and reel tracking</span>
 <button class="ia-btn ia-btn-primary" onclick="openAddShipmentForm()" style="padding: 0.4rem 0.8rem; font-size: 0.7rem;">
 + Add Shipment
 </button>
 </div>
 <div id="addShipmentForm" style="display: none; margin-bottom: 1.5rem; padding: 1rem; border: 1px solid var(--border); background: var(--surface-2);">
 <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
 <div><label for="shipProductTitle" style="font-size: 0.65rem; color: var(--muted);">Product Title</label><input type="text" id="shipProductTitle" class="ia-input" placeholder="e.g. Classic T-Shirt"></div>
 <div><label for="shipSentAt" style="font-size: 0.65rem; color: var(--muted);">Sent At</label><input type="date" id="shipSentAt" class="ia-input"></div>
 <div><label for="shipDueDate" style="font-size: 0.65rem; color: var(--muted);">Reel Due Date</label><input type="date" id="shipDueDate" class="ia-input"></div>
 <div><label for="shipImage" style="font-size: 0.65rem; color: var(--muted);">Image URL (optional)</label><input type="text" id="shipImage" class="ia-input" placeholder="https://..."></div>
 </div>
 <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem;">
 <button class="ia-btn ia-btn-primary" onclick="submitShipment()" style="padding: 0.4rem 0.8rem; font-size: 0.7rem;">Save</button>
 <button class="ia-btn ia-btn-ghost" onclick="closeAddShipmentForm()" style="padding: 0.4rem 0.8rem; font-size: 0.7rem;">Cancel</button>
 </div>
 </div>
 <div style="overflow-x: auto;">
 <table class="ia-ship-table">
 <thead><tr><th>Product</th><th>Sent</th><th>Due</th><th>Status</th><th>Reel URL</th><th>Actions</th></tr></thead>
 <tbody id="shipmentsTableBody"><tr><td colspan="6" style="text-align:center; padding: 2rem; color: var(--muted);">Loading...</td></tr></tbody>
 </table>
 </div>
 </div>
<div class="ia-tab-content" id="tab-payouts">
 <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
 <span style="font-size: 0.75rem; color: var(--muted);">Monthly commission payouts</span>
 <button class="ia-btn ia-btn-primary" onclick="generatePayouts()" style="padding: 0.4rem 0.8rem; font-size: 0.7rem;">
 Generate Payouts
 </button>
 </div>
 <div style="overflow-x: auto;">
 <table class="ia-payout-table">
 <thead><tr><th>Month</th><th>Orders</th><th>Revenue</th><th>Commission %</th><th>Amount Due</th><th>Status</th><th>Action</th></tr></thead>
 <tbody id="payoutsTableBody"><tr><td colspan="7" style="text-align:center; padding: 2rem; color: var(--muted);">Loading...</td></tr></tbody>
 </table>
 </div>
 </div>
 <div class="ia-modal-actions">
 <button class="ia-btn ia-btn-ghost" onclick="closeModal('iaStatsModal')">Close</button>
 </div>
 </div>
 </div>
<div class="ia-drawer-overlay" id="iaPayoutsDrawer" onclick="handleDrawerOverlay(event)">
 <aside class="ia-drawer" onclick="event.stopPropagation()">
 <div class="ia-drawer-head">
 <div>
 <div class="ia-drawer-title">Payouts Ledger</div>
 <div class="ia-drawer-sub"><span id="iaPayoutDrawerName">—</span> · <span id="iaPayoutDrawerCode" style="color:var(--muted);font-weight:500;font-size:0.85rem;">—</span></div>
 </div>
 <button class="ia-drawer-close" onclick="closePayoutsDrawer()" aria-label="Close">×</button>
 </div>
 <div class="ia-drawer-body">
 <div class="ia-payout-summary" style="grid-template-columns: repeat(2, 1fr);">
 <div class="ia-payout-summary-cell">
 <div class="lbl">Total Paid</div>
 <div class="val" id="iaDrawerTotalPaid">₹0</div>
 </div>
 <div class="ia-payout-summary-cell">
 <div class="lbl">Pending</div>
 <div class="val" id="iaDrawerPending">₹0</div>
 </div>
 </div>
 <div class="ia-payout-form">
 <div class="ia-payout-form-title">Add Payout</div>
 <div class="ia-payout-form-row">
 <div class="ia-form-group">
 <label for="poStart" style="font-size:0.65rem;">Period Start</label>
 <input type="date" id="poStart" class="ia-input">
 </div>
 <div class="ia-form-group">
 <label for="poEnd" style="font-size:0.65rem;">Period End</label>
 <input type="date" id="poEnd" class="ia-input">
 </div>
 </div>
 <div class="ia-payout-form-row">
 <div class="ia-form-group">
 <label for="poAmount" style="font-size:0.65rem;">Amount (INR)</label>
 <input type="number" id="poAmount" class="ia-input" min="0" step="0.01" placeholder="0.00">
 </div>
 <div class="ia-form-group">
 <label for="poRef" style="font-size:0.65rem;">Reference (Optional)</label>
 <input type="text" id="poRef" class="ia-input" placeholder="UPI ref / Txn ID">
 </div>
 </div>
 <div class="ia-form-group">
 <label for="poNotes" style="font-size:0.65rem;">Notes (Optional)</label>
 <input type="text" id="poNotes" class="ia-input" placeholder="Internal note">
 </div>
 <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
 <button class="ia-btn ia-btn-primary" id="iaAddPayoutBtn" onclick="submitNewPayout()" style="flex:1;">Record Payout</button>
 <button class="ia-btn" onclick="clearPayoutForm()" style="flex:0 0 auto;">Reset</button>
 </div>
 </div>
 <div class="ia-payout-list-header">History</div>
 <div id="iaPayoutList">
 <div class="ia-payout-empty">Loading…</div>
 </div>
 </div>
 </aside>
 </div>

<!-- Messages Page -->
<div class="ia-content hidden" id="page-messages">
  <div class="ia-messages-container">
    <div class="ia-messages-header">
      <h2 class="ia-lb-page-title">Message Center</h2>
      <button class="ia-btn ia-btn-primary" onclick="openNewMessageModal()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        New Message
      </button>
    </div>

    <!-- Message Filters -->
    <div class="ia-messages-tabs">
      <button class="ia-tab-btn active" onclick="filterMessages('all', this)">All Messages</button>
      <button class="ia-tab-btn" onclick="filterMessages('direct', this)">Direct</button>
      <button class="ia-tab-btn" onclick="filterMessages('broadcast', this)">Broadcasts</button>
    </div>

    <!-- Influencer Filter Dropdown -->
    <div class="ia-messages-filter-row">
      <select id="messageInfluencerFilter" onchange="filterByInfluencer()" style="padding: 0.6rem 2rem 0.6rem 0.75rem; border: 1px solid var(--border); border-radius: 4px; background: var(--surface); color: var(--text); font-size: 0.8rem;">
        <option value="">All Influencers</option>
      </select>
    </div>

    <!-- Messages List -->
    <div id="messagesList" class="ia-messages-list">
      <div class="ia-empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <p>No messages yet</p>
      </div>
    </div>
  </div>
</div>

<!-- New Message Modal -->
<div class="ia-modal-overlay" id="newMessageModalOverlay" onclick="handleOverlayClick(event, 'newMessageModalOverlay')">
<div class="ia-modal-box" id="newMessageModal" style="max-width:600px;">
  <div class="ia-modal-content">
    <div class="ia-modal-header">
      <h3>Send Message</h3>
      <button class="ia-modal-close" onclick="closeNewMessageModal()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="ia-modal-body">
      <!-- Message Type Toggle -->
      <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem;">
        <label style="flex: 1; cursor: pointer;">
          <input type="radio" name="messageType" value="direct" checked onchange="toggleMessageType()" style="margin-right: 0.5rem;">
          Direct Message
        </label>
        <label style="flex: 1; cursor: pointer;">
          <input type="radio" name="messageType" value="broadcast" onchange="toggleMessageType()" style="margin-right: 0.5rem;">
          Broadcast to All
        </label>
      </div>

      <!-- Recipient Select (hidden for broadcast) -->
      <div class="ia-form-group" id="recipientSelectGroup">
        <label>Select Influencer</label>
        <select id="messageRecipient" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 4px; background: var(--surface); color: var(--text);">
          <option value="">Loading...</option>
        </select>
      </div>

      <!-- Subject -->
      <div class="ia-form-group">
        <label>Subject (Optional)</label>
        <input type="text" id="messageSubject" placeholder="Enter subject..." style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 4px; background: var(--surface); color: var(--text);">
      </div>

      <!-- Message Content -->
      <div class="ia-form-group">
        <label>Message *</label>
        <textarea id="messageContent" rows="6" placeholder="Type your message..." required style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 4px; background: var(--surface); color: var(--text); resize: vertical; font-family: inherit;"></textarea>
      </div>
    </div>
    <div class="ia-modal-footer">
      <button class="ia-btn" onclick="closeNewMessageModal()">Cancel</button>
      <button class="ia-btn ia-btn-primary" onclick="sendMessage()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
        Send Message
      </button>
    </div>
  </div>
</div>
</div>

<div id="iaToast" class="ia-toast"></div>
</div>
