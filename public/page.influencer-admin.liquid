// ─── TOAST ───────────────────────────────────────────────────────────────────
let toastTimer;
function showToast(msg, isError = false) {
  const t = document.getElementById('iaToast');
  clearTimeout(toastTimer);
  t.textContent = msg;
  t.className = 'ia-toast' + (isError ? ' error' : '');
