function getMonthName(monthNum) {
  const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
  return months[parseInt(monthNum) - 1];
}

// Search Shopify products
async function searchShopifyProducts() {
  const search = document.getElementById('srProductSearch').value;
  
  try {
    const res = await fetch(`${API}/shopify-products?search=${encodeURIComponent(search)}&limit=20`, {
      headers: { 'Authorization': `Bearer ${authToken}` }
    });
    const data = await res.json();
    
    if (data.success) {
      const grid = document.getElementById('srProductGrid');
      if (data.products.length === 0) {
        grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 3rem; color: var(--muted);"><p>No products found</p></div>';
        return;
      }
      
      grid.innerHTML = data.products.map(p => {
        const imageUrl = p.images[0]?.src || '';
        return `
          <div style="border: 1px solid var(--border); background: var(--surface); overflow: hidden;">
            ${imageUrl ? `<img src="${imageUrl}" style="width: 100%; height: 200px; object-fit: cover;">` : '<div style="width: 100%; height: 200px; background: var(--subtle); display: flex; align-items: center; justify-content: center; color: var(--muted);">No Image</div>'}
            <div style="padding: 1rem;">
              <div style="font-weight: 600; font-size: 0.9rem; margin-bottom: 0.5rem;">${p.title}</div>
              <div style="font-size: 0.75rem; color: var(--muted); margin-bottom: 0.75rem;">₹${p.variants[0]?.price || '0'}</div>
              <button class="ia-btn ia-btn-primary" onclick="assignProductToInfluencer(${p.id}, '${p.title.replace(/'/g, "\\'")}', '${imageUrl}')" style="width: 100%; padding: 0.5rem; font-size: 0.7rem;">
                Assign to Ambassador
              </button>
            </div>
          </div>
        `;
      }).join('');
    }
  } catch (e) {
    console.error('Search Shopify products error:', e);
  }
}

