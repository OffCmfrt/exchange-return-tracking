  padding: 0.5rem 1rem;
  font-size: 0.75rem;
  border-radius: 6px;
}

.ia-lb-stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}
.ia-lb-stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  transition: all var(--transition);
}
.ia-lb-stat-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  border-color: var(--border-hover);
}
.ia-lb-stat-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ia-lb-stat-label {
  font-size: 0.75rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.25rem;
}
.ia-lb-stat-value {
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: -0.02em;
}

/* Podium */
.ia-lb-podium-container {
  margin-bottom: 2.5rem;
  min-height: 280px;
}
.ia-lb-podium-loading {
  text-align: center;
  padding: 4rem;
  color: var(--muted);
}
.ia-lb-podium {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 1.5rem;
  padding: 2rem 0;
}
.ia-lb-podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all var(--transition);
}
.ia-lb-podium-item:hover {
  transform: translateY(-5px);
}
.ia-lb-podium-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
