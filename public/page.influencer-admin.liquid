{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Influencer HQ - Admin</title>
{% comment %}
  OFFCOMFRT — Influencer Admin Dashboard (Ultra-Premium Edition)
  Monochromatic B&W • Razor-Sharp Borders • Micro-Animations
{% endcomment %}

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  background: #000000;
  margin: 0;
  padding: 0;
  overflow-x: auto;
}

:root {
  --bg: #000000;
  --surface: #0a0a0a;
  --surface-2: #111111;
  --border: #1f1f1f;
  --border-hover: #3a3a3a;
  --text: #ffffff;
  --muted: #606060;
  --subtle: #282828;
  --accent-line: #ffffff;
  --danger: #ff3b3b;
  --success: #22c55e;
  --warning: #f59e0b;
  --radius: 0px;
  --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.ia-wrap {
  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ── LOADING ── */
.ia-loading {
  position: fixed; inset: 0;
  background: var(--bg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  z-index: 9999;
  gap: 1.5rem;
  transition: opacity 0.4s ease;
}
.ia-loading.out { opacity: 0; pointer-events: none; }
.ia-spinner {
  width: 36px; height: 36px;
  border: 2px solid var(--border);
  border-top-color: var(--text);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.ia-loading p {
  font-size: 0.7rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--muted);
}
@keyframes spin { to { transform: rotate(360deg); } }
.ia-spin { animation: spin 1s linear infinite; }

/* ── AUTH ── */
.ia-auth {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh;
}
.ia-auth-card {
  width: 100%; max-width: 380px;
  border: 1px solid var(--border);
  background: var(--surface);
  padding: 3rem;
  animation: fadeUp 0.4s ease both;
}
.ia-auth-logo {
  font-size: 0.65rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 2.5rem;
  text-align: center;
}
.ia-auth-card h2 {
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 2rem;
  text-align: center;
}
.ia-auth-err {
  font-size: 0.75rem;
  color: var(--danger);
  text-align: center;
  margin-top: 1rem;
  display: none;
}
.ia-auth-err.show { display: block; }

/* ── LAYOUT ── */
.ia-layout { display: flex; min-height: 100vh; }

.ia-sidebar {
  width: 220px;
  background: var(--surface);
  border-right: 1px solid var(--border);
  padding: 2rem 0;
  display: flex;
  flex-direction: column;
  position: fixed; top: 0; left: 0; bottom: 0;
  z-index: 100;
  transition: transform var(--transition);
  box-shadow: 2px 0 10px rgba(0, 0, 0, 0.3);
}

.ia-sidebar.collapsed {
  transform: translateX(-100%);
}

.ia-sidebar-toggle {
  display: flex;
  position: fixed;
  top: 1.5rem;
  left: 230px;
  z-index: 101;
  width: 28px;
  height: 28px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 2px;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  transition: all var(--transition);
}

.ia-sidebar-toggle.shifted {
  left: 1rem;
}

.ia-sidebar-toggle:hover {
  background: var(--subtle);
  border-color: var(--border-hover);
}

.ia-sidebar-toggle svg {
  width: 16px;
  height: 16px;
  stroke: var(--text);
  transition: transform var(--transition);
}

.ia-sidebar-toggle.shifted svg {
  transform: rotate(180deg);
}

.ia-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 99;
  backdrop-filter: blur(2px);
}

.ia-overlay.active {
  display: block;
}
.ia-sidebar-logo {
  padding: 0 1.5rem 2rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 1.5rem;
}
.ia-sidebar-logo span {
  font-size: 0.6rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--muted);
  display: block;
  margin-bottom: 0.3rem;
}
.ia-sidebar-logo strong {
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.ia-sidebar-nav {
  flex: 1;
  padding: 0 1rem;
}
.ia-nav-item {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.7rem 0.75rem;
  border-radius: 2px;
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  color: var(--muted);
  cursor: pointer;
  transition: all var(--transition);
  text-transform: uppercase;
}
.ia-nav-item:hover, .ia-nav-item.active { color: var(--text); background: var(--subtle); }
.ia-sidebar-footer {
  padding: 1.5rem;
  border-top: 1px solid var(--border);
}
.ia-logout-btn {
  width: 100%;
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 0.6rem 1rem;
  background: transparent;
  border: 1px solid var(--border);
  color: var(--muted);
  cursor: pointer;
  transition: all var(--transition);
  font-family: inherit;
}
.ia-logout-btn:hover { border-color: var(--danger); color: var(--danger); }

/* ── MAIN ── */
.ia-main {
  flex: 1;
  margin-left: 220px;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  transition: margin-left var(--transition);
}

.ia-main.expanded {
  margin-left: 0;
}
.ia-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem 2.5rem;
  border-bottom: 1px solid var(--border);
  background: var(--bg);
  position: sticky; top: 0;
  z-index: 50;
}

.ia-topbar-mobile-toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
  margin-right: 1rem;
}

.ia-topbar-mobile-toggle svg {
  width: 24px;
  height: 24px;
  stroke: var(--text);
}
.ia-topbar h1 {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}
.ia-topbar-meta {
  font-size: 0.7rem;
  color: var(--muted);
  letter-spacing: 0.1em;
}

.ia-content { padding: 2rem 1.5rem; flex: 1; max-width: 100%; overflow-x: auto; }

/* ── STAT STRIP ── */
.ia-stat-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  margin-bottom: 2.5rem;
}
.ia-stat-cell {
  background: var(--surface);
  padding: 1.75rem 2rem;
  position: relative;
  overflow: hidden;
  transition: background var(--transition);
}
.ia-stat-cell:hover { background: var(--surface-2); }
.ia-stat-cell::before {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: var(--text);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
}
.ia-stat-cell:hover::before { transform: scaleX(1); }
.ia-stat-label {
  font-size: 0.65rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.75rem;
  font-weight: 500;
}
.ia-stat-value {
  font-size: 2.2rem;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.02em;
}

/* ── TABLE SECTION ── */
.ia-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.25rem;
}
.ia-section-title {
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 600;
}
.ia-table-wrap {
  border: 1px solid var(--border);
  overflow-x: auto;
  overflow-y: visible;
  -webkit-overflow-scrolling: touch;
  position: relative;
}

/* Custom scrollbar for table */
.ia-table-wrap::-webkit-scrollbar {
  height: 8px;
}
.ia-table-wrap::-webkit-scrollbar-track {
  background: var(--surface);
}
.ia-table-wrap::-webkit-scrollbar-thumb {
  background: var(--border-hover);
  border-radius: 4px;
}
.ia-table-wrap::-webkit-scrollbar-thumb:hover {
  background: var(--muted);
}

.ia-table {
  width: 100%;
  min-width: 980px;
  border-collapse: collapse;
}
.ia-table thead tr {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
}
.ia-table th {
  padding: 0.85rem 0.75rem;
  font-size: 0.58rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  text-align: left;
  font-weight: 600;
  white-space: nowrap;
}
.ia-table td {
  padding: 0.9rem 0.75rem;
  border-bottom: 1px solid var(--border);
  font-size: 0.8rem;
  vertical-align: middle;
}

/* Sticky Actions column - always visible */
.ia-table th:last-child,
.ia-table td:last-child {
  position: sticky;
  right: 0;
  background: var(--bg);
  z-index: 2;
  border-left: 1px solid var(--border);
  box-shadow: -4px 0 8px rgba(0, 0, 0, 0.3);
}
.ia-table thead th:last-child {
  background: var(--surface);
}
.ia-table tbody tr:hover td:last-child {
  background: var(--surface);
}
.ia-table tbody tr { transition: background var(--transition); }
.ia-table tbody tr:hover td { background: var(--surface); }
.ia-table tbody tr:last-child td { border-bottom: none; }
.ia-table .td-name { font-weight: 600; letter-spacing: 0.02em; }
.ia-table .td-code {
  font-family: 'SF Mono', 'Fira Code', monospace;
  font-size: 0.78rem;
  background: var(--subtle);
  padding: 0.2rem 0.6rem;
  letter-spacing: 0.08em;
  border: 1px solid var(--border);
  display: inline-block;
}
.ia-table .td-commission {
  font-weight: 700;
  font-size: 0.9rem;
}
.ia-table .td-discount {
  font-weight: 700;
  font-size: 0.9rem;
  color: var(--success);
}
.ia-table .td-usage {
  font-size: 0.85rem;
  color: var(--muted);
  text-align: center;
}
.ia-table .td-orders {
  color: var(--muted);
  font-size: 0.8rem;
}
.ia-table .td-date {
  color: var(--muted);
  font-size: 0.75rem;
}
.ia-copy-btn {
  display: inline-flex; align-items: center; gap: 0.3rem;
  padding: 0.3rem 0.55rem;
  background: transparent;
  border: 1px solid var(--border);
  color: var(--muted);
  font-size: 0.6rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  font-family: inherit;
  transition: all var(--transition);
  white-space: nowrap;
}
.ia-copy-btn:hover { border-color: var(--text); color: var(--text); }
.ia-copy-btn.copied { border-color: var(--success); color: var(--success); }

/* Row action buttons */
.ia-row-actions { display: flex; gap: 0.35rem; align-items: center; flex-wrap: nowrap; }
.ia-action-btn {
  padding: 0.3rem 0.55rem;
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  border: 1px solid;
  background: transparent;
  transition: all var(--transition);
  white-space: nowrap;
}
.ia-action-btn.edit { border-color: var(--border); color: var(--muted); }
.ia-action-btn.edit:hover { border-color: var(--text); color: var(--text); }
.ia-action-btn.remove { border-color: transparent; color: var(--muted); }
.ia-action-btn.remove:hover { border-color: var(--danger); color: var(--danger); }
.ia-action-btn.view { border-color: var(--border); color: var(--success); }
.ia-action-btn.view:hover { border-color: var(--success); color: var(--success); background: rgba(34, 197, 94, 0.1); }

/* ── EMPTY STATE ── */
.ia-empty {
  text-align: center;
  padding: 5rem 2rem;
  color: var(--muted);
}
.ia-empty h3 {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  margin-bottom: 0.5rem;
  color: var(--text);
}
.ia-empty p { font-size: 0.78rem; }

/* ── BUTTONS ── */
.ia-btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  font-family: inherit;
  font-weight: 600;
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  cursor: pointer;
  border: none;
  transition: all var(--transition);
}
.ia-btn-primary {
  background: var(--text);
  color: var(--bg);
}
.ia-btn-primary:hover {
  background: #d4d4d4;
  transform: translateY(-1px);
}
.ia-btn-ghost {
  background: transparent;
  color: var(--muted);
  border: 1px solid var(--border);
}
.ia-btn-ghost:hover { border-color: var(--border-hover); color: var(--text); }
.ia-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

/* ── FORM ── */
.ia-form-group { margin-bottom: 1rem; }
.ia-form-group label {
  display: block;
  font-size: 0.62rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.5rem;
  font-weight: 600;
}
.ia-input {
  width: 100%;
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 0.8rem 1rem;
  color: var(--text);
  font-family: inherit;
  font-size: 0.88rem;
  transition: border-color var(--transition);
  outline: none;
}
.ia-input:focus { border-color: var(--text); }
.ia-input::placeholder { color: var(--muted); }
.ia-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.ia-form-hint {
  font-size: 0.65rem;
  color: var(--muted);
  margin-top: 0.4rem;
  letter-spacing: 0.05em;
}

/* ── MODAL ── */
.ia-modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.9);
  backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  z-index: 200;
  opacity: 0; pointer-events: none;
  transition: opacity 0.25s ease;
  padding: 1rem;
}
.ia-modal-overlay.open { opacity: 1; pointer-events: all; }
.ia-modal {
  background: var(--surface);
  border: 1px solid var(--border);
  width: 100%; max-width: 520px;
  max-height: 90vh;
  overflow-y: auto;
  padding: 2rem;
  transform: translateY(16px) scale(0.98);
  transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
}
.ia-modal-overlay.open .ia-modal { transform: translateY(0) scale(1); }
.ia-modal-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border);
}
.ia-modal-title {
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}
.ia-modal-close {
  background: none; border: none;
  color: var(--muted); cursor: pointer;
  font-size: 1.2rem; line-height: 1;
  padding: 0.25rem;
  transition: color var(--transition);
}
.ia-modal-close:hover { color: var(--text); }
.ia-modal-actions {
  display: flex; gap: 0.75rem;
  margin-top: 1.5rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}
.ia-modal-actions .ia-btn { flex: 1; justify-content: center; }
.ia-modal-error {
  font-size: 0.72rem;
  color: var(--danger);
  margin-top: 0.75rem;
  display: none;
}
.ia-modal-error.show { display: block; }

/* ── TOAST ── */
.ia-toast {
  position: fixed;
  bottom: 2rem; right: 2rem;
  background: var(--text);
  color: var(--bg);
  padding: 1rem 1.5rem;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  border-left: 3px solid var(--bg);
  transform: translateY(4rem);
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
  z-index: 9000;
  pointer-events: none;
}
.ia-toast.show { transform: translateY(0); opacity: 1; }
.ia-toast.error { background: var(--danger); color: #fff; }

/* ── STATS MODAL STYLES ── */
.ia-stats-filter {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 1.5rem;
  margin-bottom: 1.5rem;
}
.ia-filter-row {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}
.ia-filter-group {
  flex: 1;
  min-width: 150px;
}
.ia-filter-group label {
  display: block;
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.5rem;
  font-weight: 600;
}
.ia-filter-label {
  display: block;
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.5rem;
  font-weight: 600;
}
.ia-range-buttons {
  display: flex;
  gap: 0;
  border: 1px solid var(--border);
}
.ia-range-btn {
  padding: 0.5rem 1rem;
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 600;
  font-family: inherit;
  background: transparent;
  border: none;
  border-right: 1px solid var(--border);
  color: var(--muted);
  cursor: pointer;
  transition: all var(--transition);
}
.ia-range-btn:last-child { border-right: none; }
.ia-range-btn:hover { color: var(--text); background: var(--surface-2); }
.ia-range-btn.active {
  background: var(--text);
  color: var(--bg);
}
.ia-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
}
.ia-stat-box {
  background: var(--surface);
  padding: 1.5rem;
  text-align: center;
}
.ia-stat-box.highlight {
  background: var(--surface-2);
}
.ia-stat-box-label {
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.75rem;
}
.ia-stat-box-value {
  font-size: 1.75rem;
  font-weight: 900;
  letter-spacing: -0.02em;
  color: var(--text);
}
.ia-stat-box.highlight .ia-stat-box-value {
  color: var(--success);
}
.ia-stat-box-sub {
  font-size: 0.65rem;
  color: var(--muted);
  margin-top: 0.5rem;
  letter-spacing: 0.1em;
}
.ia-conversions-list {
  border: 1px solid var(--border);
  max-height: 300px;
  overflow-y: auto;
}
.ia-conversion-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  transition: background var(--transition);
}
.ia-conversion-item:hover { background: var(--surface-2); }
.ia-conversion-item:last-child { border-bottom: none; }
.ia-conversion-order {
  font-weight: 600;
  font-size: 0.85rem;
  letter-spacing: 0.02em;
}
.ia-conversion-date {
  font-size: 0.7rem;
  color: var(--muted);
  margin-top: 0.2rem;
}
.ia-conversion-total {
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--success);
}
.ia-conversion-empty {
  text-align: center;
  padding: 3rem;
  color: var(--muted);
  font-size: 0.8rem;
}
.ia-conversion-loading {
  text-align: center;
  padding: 2rem;
}
.ia-conversion-loading::after {
  content: '';
  display: inline-block;
  width: 24px;
  height: 24px;
  border: 2px solid var(--border);
  border-top-color: var(--text);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* ── LEADERBOARD ── */
.ia-leaderboard-card {
  border: 1px solid var(--border);
  background: var(--surface);
  margin-bottom: 2rem;
}
.ia-leaderboard-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
}
.ia-leaderboard-header h3 {
  font-size: 0.85rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
}
.ia-lb-range-btns { display: flex; gap: 0.5rem; }
.ia-lb-range-btn {
  padding: 0.35rem 0.75rem; font-size: 0.7rem; letter-spacing: 0.05em;
  background: transparent; border: 1px solid var(--border); color: var(--muted);
