}
.ia-lb-range-btn.active, .ia-lb-range-btn:hover {
  background: var(--text); color: var(--bg); border-color: var(--text);
}
.ia-lb-table { width: 100%; border-collapse: collapse; }
.ia-lb-table th {
  text-align: left; padding: 0.75rem 1.5rem; font-size: 0.6rem;
  letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted);
  border-bottom: 1px solid var(--border); background: var(--surface-2);
}
.ia-lb-table td {
  padding: 0.85rem 1.5rem; font-size: 0.8rem; border-bottom: 1px solid var(--border);
}
.ia-lb-table tr:last-child td { border-bottom: none; }
.ia-lb-rank {
  display: inline-flex; align-items: center; justify-content: center;
  width: 24px; height: 24px; border-radius: 50%;
  background: var(--subtle); font-size: 0.7rem; font-weight: 700;
}
.ia-lb-rank.top1 { background: var(--text); color: var(--bg); }
.ia-lb-name { font-weight: 600; }
.ia-lb-revenue { font-weight: 700; }
.ia-lb-empty { text-align: center; padding: 2rem; color: var(--muted); font-size: 0.8rem; }

/* ── PREMIUM LEADERBOARD PAGE ─ */
.ia-lb-page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 2rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border);
}
.ia-lb-page-title {
  font-size: 1.75rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  margin: 0 0 0.5rem 0;
  background: linear-gradient(135deg, #fff 0%, #a0aec0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.ia-lb-page-subtitle {
  font-size: 0.9rem;
  color: var(--muted);
  margin: 0;
}
.ia-lb-range-selector {
  display: flex;
  gap: 0.5rem;
  background: var(--surface);
  padding: 0.5rem;
