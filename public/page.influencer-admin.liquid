  document.querySelectorAll('[data-srtab]').forEach(b => b.classList.remove('active'));
  btnEl.classList.add('active');
  
  // Hide all tabs
  document.querySelectorAll('.sr-tab-content').forEach(tab => tab.style.display = 'none');
  
