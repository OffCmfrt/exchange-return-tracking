{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
<meta name="robots" content="noindex, nofollow">
<title>Become an Offcomfrt Ambassador</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;500;700;900&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #fafafa;
  --surface: #ffffff;
  --border: #e8e8e8;
  --border-strong: #1a1a1a;
  --text: #0a0a0a;
  --muted: #6b6b6b;
  --error: #c0392b;
  --success: #1a7f3e;
  --warning: #d97706;
  --tier-blue: #3b82f6;
  --tier-green: #22c55e;
  --tier-purple: #a855f7;
  --tier-gold: #f59e0b;
  --transition: 0.32s cubic-bezier(0.22, 0.61, 0.36, 1);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Inter', -apple-system, sans-serif;
  -webkit-font-smoothing: antialiased;
  font-size: 15px;
  line-height: 1.55;
  min-height: 100vh;
}
.ia-shell { max-width: 960px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }

/* ── HERO ── */
.ia-hero {
  text-align: center;
  margin-bottom: 4rem;
  animation: fadeUp 0.8s ease both;
}
.ia-eyebrow {
  font-size: 0.7rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 600;
  margin-bottom: 1.25rem;
}
.ia-hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
}
.ia-hero h1 em { font-style: italic; font-weight: 500; }
.ia-hero p {
  max-width: 580px;
  margin: 0 auto;
  color: var(--muted);
  font-size: 1.05rem;
}

.ia-benefits {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
  margin: 3rem 0 0;
}
.ia-benefit {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 1.5rem;
  text-align: left;
  transition: all var(--transition);
}
.ia-benefit:hover {
  border-color: var(--border-strong);
  transform: translateY(-2px);
}
.ia-benefit-num {
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}
.ia-benefit h3 {
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  margin-bottom: 0.4rem;
}
.ia-benefit p {
  font-size: 0.85rem;
  color: var(--muted);
  line-height: 1.5;
}

/* ── FORM CARD ── */
.ia-card {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: clamp(2rem, 5vw, 3.5rem);
  animation: fadeUp 0.8s 0.15s ease both;
}

.ia-progress {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
}
.ia-progress-step {
  flex: 1;
  min-width: 100px;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.ia-progress-circle {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 1.5px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--muted);
  background: var(--surface);
  transition: all var(--transition);
  flex-shrink: 0;
}
.ia-progress-step.active .ia-progress-circle {
  border-color: var(--text);
  background: var(--text);
  color: var(--surface);
}
.ia-progress-step.complete .ia-progress-circle {
  border-color: var(--text);
  background: var(--text);
  color: var(--surface);
}
.ia-progress-label {
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--muted);
  white-space: nowrap;
}
.ia-progress-step.active .ia-progress-label,
.ia-progress-step.complete .ia-progress-label { color: var(--text); }
.ia-progress-line {
  flex: 0.5;
  min-width: 20px;
  height: 1px;
  background: var(--border);
  transition: background var(--transition);
}
.ia-progress-line.complete { background: var(--text); }

.ia-step { display: none; animation: fadeUp 0.5s ease both; }
.ia-step.active { display: block; }

.ia-step-header { margin-bottom: 2rem; }
.ia-step-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.75rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}
.ia-step-sub { color: var(--muted); font-size: 0.95rem; }

.ia-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}
.ia-grid.single { grid-template-columns: 1fr; }

.ia-field { margin-bottom: 1.5rem; }
.ia-field.full { grid-column: 1 / -1; }
.ia-label {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-weight: 700;
  margin-bottom: 0.6rem;
}
.ia-label .req { color: var(--error); margin-left: 2px; }
.ia-label .opt { color: var(--muted); font-weight: 500; letter-spacing: 0.12em; }
.ia-input, .ia-select, .ia-textarea {
  width: 100%;
  padding: 0.95rem 1rem;
  border: 1px solid var(--border);
  background: var(--bg);
  font-family: inherit;
  font-size: 0.95rem;
  color: var(--text);
  transition: all var(--transition);
}
.ia-input:focus, .ia-select:focus, .ia-textarea:focus {
  outline: none;
  border-color: var(--text);
  background: var(--surface);
}
.ia-input.has-error, .ia-select.has-error, .ia-textarea.has-error { border-color: var(--error); }
.ia-textarea { min-height: 110px; resize: vertical; }
.ia-help { font-size: 0.78rem; color: var(--muted); margin-top: 0.5rem; }
.ia-error { font-size: 0.8rem; color: var(--error); margin-top: 0.5rem; min-height: 1.1em; }

/* ── TIER CALCULATOR ── */
.ia-tier-widget {
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border: 2px solid var(--border);
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  text-align: center;
  transition: all var(--transition);
}
.ia-tier-widget.active {
  border-color: var(--tier-blue);
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
}
.ia-tier-eyebrow {
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 700;
  margin-bottom: 0.75rem;
}
.ia-tier-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}
.ia-tier-name.rising { color: var(--tier-blue); }
.ia-tier-name.growing { color: var(--tier-green); }
.ia-tier-name.established { color: var(--tier-purple); }
.ia-tier-name.top { color: var(--tier-gold); }
.ia-tier-limit {
  font-size: 0.9rem;
  color: var(--text);
  font-weight: 600;
  margin-bottom: 1rem;
}
.ia-tier-benefits {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}
.ia-tier-benefit {
  background: var(--surface);
  padding: 0.75rem;
  border-radius: 8px;
  border: 1px solid var(--border);
}
.ia-tier-benefit.highlight {
  background: var(--text);
  color: var(--surface);
  border-color: var(--text);
}
.ia-tier-benefit-range {
  font-size: 0.7rem;
  color: var(--muted);
  margin-bottom: 0.25rem;
}
.ia-tier-benefit.highlight .ia-tier-benefit-range { color: rgba(255,255,255,0.7); }
.ia-tier-benefit-value {
  font-size: 0.85rem;
  font-weight: 700;
}

/* ── SHIPPING SECTION ── */
.ia-section-label {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text);
  margin: 2rem 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--text);
}
.ia-section-label:first-of-type { margin-top: 0; }
.ia-radio-group {
  display: flex;
  gap: 1.5rem;
  margin-top: 0.5rem;
}
.ia-radio-option {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  font-size: 0.95rem;
}
.ia-radio-option input { margin: 0; cursor: pointer; }
.ia-radio-option span { cursor: pointer; }

/* ── PRODUCT SELECTION ── */
.ia-product-counter {
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 1rem;
  margin-bottom: 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.ia-product-counter-text {
  font-size: 0.9rem;
  color: var(--muted);
}
.ia-product-counter-text strong { color: var(--text); }
.ia-product-counter-limit {
  font-size: 0.8rem;
  padding: 0.4rem 0.8rem;
  border-radius: 20px;
  font-weight: 600;
}
.ia-product-counter-limit.warning {
  background: #fef3c7;
  color: var(--warning);
}
.ia-product-counter-limit.success {
  background: #dcfce7;
  color: var(--success);
}
.ia-product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.ia-product-card {
  border: 2px solid var(--border);
  padding: 1rem;
  cursor: pointer;
  transition: all var(--transition);
  position: relative;
}
.ia-product-card:hover {
  border-color: var(--text);
  transform: translateY(-2px);
}
.ia-product-card.selected {
  border-color: var(--text);
  background: var(--bg);
}
.ia-product-card.selected::after {
  content: '✓';
  position: absolute;
  top: 0.5rem;
  right: 0.5rem;
  width: 24px;
  height: 24px;
  background: var(--text);
  color: var(--surface);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
}
.ia-product-card.disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.ia-product-card.disabled:hover {
  border-color: var(--border);
  transform: none;
}
.ia-product-img {
  width: 100%;
  height: 120px;
  object-fit: contain;
  margin-bottom: 0.75rem;
  background: var(--bg);
}
.ia-product-title {
  font-size: 0.85rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
  line-height: 1.3;
}
.ia-product-price {
  font-size: 0.9rem;
  color: var(--muted);
  font-weight: 600;
}
.ia-products-loading {
  text-align: center;
  padding: 2rem;
  color: var(--muted);
}

/* ── CHECKBOXES ── */
.ia-checkbox-row {
  display: flex;
  gap: 0.75rem;
  align-items: flex-start;
  font-size: 0.88rem;
  color: var(--muted);
  margin-top: 0.5rem;
}
.ia-checkbox-row input { margin-top: 3px; flex-shrink: 0; }
.ia-checkbox-row a { color: var(--text); text-decoration: underline; }

/* ── BUTTONS ── */
.ia-actions {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}
.ia-btn {
  padding: 1rem 2rem;
  font-family: inherit;
  font-size: 0.75rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  font-weight: 700;
  border: 1.5px solid var(--text);
  background: var(--text);
  color: var(--surface);
  cursor: pointer;
  transition: all var(--transition);
}
.ia-btn:hover { background: transparent; color: var(--text); }
.ia-btn:disabled { opacity: 0.45; cursor: not-allowed; }
.ia-btn.secondary { background: transparent; color: var(--text); }
.ia-btn.secondary:hover { background: var(--text); color: var(--surface); }

/* ── SUCCESS SCREEN ── */
.ia-success { display: none; text-align: center; padding: 2rem 0; animation: fadeUp 0.6s ease both; }
.ia-success.show { display: block; }
.ia-success-mark {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 2px solid var(--text);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 2rem;
}
.ia-success-mark svg { width: 36px; height: 36px; }
.ia-success h2 {
  font-family: 'Playfair Display', serif;
  font-size: 2.4rem;
  font-weight: 700;
  margin-bottom: 1rem;
}
.ia-success > p { max-width: 500px; margin: 0 auto 2rem; color: var(--muted); }

.ia-code-card {
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 2rem;
  max-width: 480px;
  margin: 0 auto 2rem;
  text-align: center;
}
.ia-code-card-eyebrow {
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 700;
  margin-bottom: 0.75rem;
}
.ia-code-display {
  font-family: 'Playfair Display', serif;
  font-size: 2.5rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  margin-bottom: 0.5rem;
}
.ia-code-card-help { font-size: 0.85rem; color: var(--muted); }

.ia-portal-card {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 1.5rem;
  max-width: 600px;
  margin: 0 auto;
}
.ia-portal-eyebrow {
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 700;
  margin-bottom: 0.75rem;
}
.ia-portal-url-row { display: flex; gap: 0.5rem; }
.ia-portal-url {
  flex: 1;
  padding: 0.75rem 0.9rem;
  border: 1px solid var(--border);
  background: var(--bg);
  font-family: 'SFMono-Regular', Menlo, monospace;
  font-size: 0.78rem;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ia-copy-btn {
  padding: 0.75rem 1rem;
  border: 1.5px solid var(--text);
  background: var(--text);
  color: var(--surface);
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  font-weight: 700;
  text-transform: uppercase;
  cursor: pointer;
  transition: all var(--transition);
  white-space: nowrap;
}
.ia-copy-btn:hover { background: transparent; color: var(--text); }
.ia-copy-btn.copied { background: var(--success); border-color: var(--success); color: #fff; }

.ia-timeline-card {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border: 2px solid #22c55e;
  padding: 2rem;
  max-width: 600px;
  margin: 2rem auto;
  text-align: center;
}
.ia-timeline-icon {
  width: 60px;
  height: 60px;
  background: #22c55e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1rem;
}
.ia-timeline-icon svg { width: 28px; height: 28px; color: white; }
.ia-timeline-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem;
  font-weight: 700;
  margin-bottom: 0.75rem;
  color: #166534;
}
.ia-timeline-text {
  font-size: 0.95rem;
  color: #166534;
  line-height: 1.6;
}
.ia-timeline-text strong { display: block; font-size: 1.1rem; margin-bottom: 0.5rem; }
.ia-timeline-steps {
  display: flex;
  justify-content: center;
  gap: 2rem;
  margin-top: 1.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(34, 197, 94, 0.3);
}
.ia-timeline-step {
  text-align: center;
}
.ia-timeline-step-num {
  width: 28px;
  height: 28px;
  background: #22c55e;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  margin: 0 auto 0.5rem;
}
.ia-timeline-step-text {
  font-size: 0.75rem;
  color: #166534;
  font-weight: 600;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 720px) {
  .ia-shell { padding: 2.5rem 1rem 4rem; }
  .ia-benefits { grid-template-columns: 1fr; }
  .ia-grid { grid-template-columns: 1fr; }
  .ia-progress-label { display: none; }
  .ia-actions { flex-direction: column-reverse; }
  .ia-btn { width: 100%; }
  .ia-tier-benefits { grid-template-columns: repeat(2, 1fr); }
  .ia-product-grid { grid-template-columns: repeat(2, 1fr); }
  .ia-timeline-steps { flex-direction: column; gap: 1rem; }
}
</style>
</head>
<body>
<div class="ia-shell">

  <!-- HERO -->
  <header class="ia-hero">
    <p class="ia-eyebrow">Offcomfrt · Ambassador Program</p>
    <h1>Wear it. Share it.<br><em>Earn from it.</em></h1>
    <p>Apply once. Get your personal discount code. Earn commission on every order placed with it — paid out monthly.</p>

    <div class="ia-benefits">
      <div class="ia-benefit">
        <div class="ia-benefit-num">01</div>
        <h3>7% COMMISSION</h3>
        <p>On every order placed with your unique code, lifetime.</p>
      </div>
      <div class="ia-benefit">
        <div class="ia-benefit-num">02</div>
        <h3>7% OFF FOR YOUR AUDIENCE</h3>
        <p>Your followers get an exclusive discount they can't get anywhere else.</p>
      </div>
      <div class="ia-benefit">
        <div class="ia-benefit-num">03</div>
        <h3>MONTHLY PAYOUTS</h3>
        <p>Track earnings in real-time on your private dashboard. Paid via UPI.</p>
      </div>
    </div>
  </header>

  <!-- APPLICATION CARD -->
  <div class="ia-card" id="iaCard">

    <!-- Progress -->
    <div class="ia-progress" id="iaProgress">
      <div class="ia-progress-step active" data-step="1">
        <div class="ia-progress-circle">1</div>
        <div class="ia-progress-label">About You</div>
      </div>
      <div class="ia-progress-line"></div>
      <div class="ia-progress-step" data-step="2">
        <div class="ia-progress-circle">2</div>
        <div class="ia-progress-label">Audience</div>
      </div>
      <div class="ia-progress-line"></div>
      <div class="ia-progress-step" data-step="3">
        <div class="ia-progress-circle">3</div>
        <div class="ia-progress-label">Content</div>
      </div>
      <div class="ia-progress-line"></div>
      <div class="ia-progress-step" data-step="4">
        <div class="ia-progress-circle">4</div>
        <div class="ia-progress-label">Products</div>
      </div>
      <div class="ia-progress-line"></div>
      <div class="ia-progress-step" data-step="5">
        <div class="ia-progress-circle">5</div>
        <div class="ia-progress-label">Your Code</div>
      </div>
    </div>

    <!-- STEP 1 -->
    <section class="ia-step active" data-step="1">
      <div class="ia-step-header">
        <h2 class="ia-step-title">First, the basics</h2>
        <p class="ia-step-sub">We'll use these to set up your ambassador account.</p>
      </div>
      <div class="ia-grid">
        <div class="ia-field">
          <label class="ia-label" for="iaName">Full Name <span class="req">*</span></label>
          <input class="ia-input" id="iaName" type="text" autocomplete="name" maxlength="80">
          <div class="ia-error" data-error-for="name"></div>
        </div>
        <div class="ia-field">
          <label class="ia-label" for="iaEmail">Email <span class="req">*</span></label>
          <input class="ia-input" id="iaEmail" type="email" autocomplete="email" maxlength="120">
          <div class="ia-error" data-error-for="email"></div>
        </div>
        <div class="ia-field">
          <label class="ia-label" for="iaPhone">Mobile Number <span class="req">*</span></label>
          <input class="ia-input" id="iaPhone" type="tel" autocomplete="tel" inputmode="numeric" maxlength="15" placeholder="10-digit number">
          <div class="ia-error" data-error-for="phone"></div>
        </div>
        <div class="ia-field">
          <label class="ia-label" for="iaCity">City <span class="opt">(Optional)</span></label>
          <input class="ia-input" id="iaCity" type="text" autocomplete="address-level2" maxlength="60">
        </div>
      </div>
      <div class="ia-actions" style="justify-content: flex-end;">
        <button type="button" class="ia-btn" data-next="2">Continue →</button>
      </div>
    </section>

    <!-- STEP 2 -->
    <section class="ia-step" data-step="2">
      <div class="ia-step-header">
        <h2 class="ia-step-title">Tell us about your reach</h2>
        <p class="ia-step-sub">Helps us tailor commission tiers for top creators.</p>
      </div>
      
      <!-- Tier Calculator Widget (Hidden from influencers) -->
      <div class="ia-tier-widget" id="iaTierWidget" style="display:none;">
