<script>
const APPLY_API = 'https://exchange-return-tracking.onrender.com/api/influencer/apply';
const PRODUCTS_API = 'https://exchange-return-tracking.onrender.com/api/influencer/products';

let currentStep = 1;
let selectedProducts = [];
let availableProducts = [];
let productLimit = 2;
let currentTier = null;

// ── Tier Calculation ──
function calculateFollowerTier(followerCount) {
  const count = parseInt(followerCount) || 0;
  if (count < 50000) return { tier: 'Rising Star', tierKey: 'rising', limit: 2 };
  if (count < 100000) return { tier: 'Growing Creator', tierKey: 'growing', limit: 3 };
  if (count < 500000) return { tier: 'Established Influencer', tierKey: 'established', limit: 4 };
  return { tier: 'Top Tier Creator', tierKey: 'top', limit: 5 };
}

function updateTierWidget() {
  const followerCount = document.getElementById('iaFollowers').value;
  const widget = document.getElementById('iaTierWidget');
  const tierName = document.getElementById('iaTierName');
  const tierLimit = document.getElementById('iaTierLimit');
  
  if (!followerCount || followerCount < 1000) {
    widget.classList.remove('active');
    tierName.textContent = 'Enter Followers';
    tierName.className = 'ia-tier-name';
    tierLimit.textContent = '—';
    document.querySelectorAll('.ia-tier-benefit').forEach(el => el.classList.remove('highlight'));
    return;
  }
  
  const tier = calculateFollowerTier(followerCount);
  currentTier = tier;
  productLimit = tier.limit;
  
  widget.classList.add('active');
  tierName.textContent = tier.tier;
  tierName.className = `ia-tier-name ${tier.tierKey}`;
  tierLimit.textContent = `You can request up to ${tier.limit} products`;
  
  document.querySelectorAll('.ia-tier-benefit').forEach(el => {
    el.classList.toggle('highlight', el.dataset.tier === tier.tierKey);
  });
  
  // Update step 4 if visible
  if (currentStep >= 4) {
    updateProductSelection();
  }
}

// ── Product Loading ──
async function loadProducts() {
  const loading = document.getElementById('iaProductsLoading');
  const grid = document.getElementById('iaProductGrid');
  
  try {
    const res = await fetch(PRODUCTS_API);
    const data = await res.json();
    
    if (data.success && data.products) {
      availableProducts = data.products;
      renderProducts();
      loading.style.display = 'none';
      grid.style.display = 'grid';
    } else {
      loading.textContent = 'Failed to load products. Please refresh.';
    }
  } catch (err) {
    loading.textContent = 'Failed to load products. Please refresh.';
  }
}

function renderProducts() {
  const grid = document.getElementById('iaProductGrid');
  grid.innerHTML = availableProducts.map(product => {
    const sizesHtml = product.sizes && product.sizes.length > 0
      ? `<div style="display: flex; flex-wrap: wrap; gap: 0.25rem; margin-top: 0.5rem;">${product.sizes.map(s => `<span style="font-size: 0.6rem; padding: 0.15rem 0.4rem; background: var(--bg); border: 1px solid var(--border); border-radius: 3px; color: var(--muted);">${s.title}</span>`).join('')}</div>`
      : '';
    return `
      <div class="ia-product-card" data-id="${product.id}" onclick="toggleProduct('${product.id}')" style="position: relative;">
        <span style="position: absolute; top: 0.4rem; right: 0.4rem; font-size: 0.55rem; padding: 0.15rem 0.4rem; background: #dcfce7; color: #16a34a; border-radius: 3px; font-weight: 600;">IN STOCK</span>
        <img class="ia-product-img" src="${product.image || 'https://via.placeholder.com/200x120?text=No+Image'}" alt="${product.title}" onerror="this.src='https://via.placeholder.com/200x120?text=No+Image'">
        <div class="ia-product-title">${product.title}</div>
        <div class="ia-product-price">₹${parseFloat(product.price).toLocaleString('en-IN')}</div>
        ${sizesHtml}
      </div>
    `;
  }).join('');
  updateProductSelection();
}

function toggleProduct(productId) {
  if (selectedProducts.includes(productId)) {
    selectedProducts = selectedProducts.filter(id => id !== productId);
  } else {
    if (selectedProducts.length >= productLimit) {
      alert(`Your tier allows only ${productLimit} products. Please deselect one first.`);
      return;
    }
    selectedProducts.push(productId);
  }
  updateProductSelection();
}

function updateProductSelection() {
  const selectedCount = document.getElementById('iaSelectedCount');
  const maxCount = document.getElementById('iaMaxCount');
  const counterStatus = document.getElementById('iaCounterStatus');
  const maxProducts = document.getElementById('iaMaxProducts');
  
  maxCount.textContent = productLimit;
  maxProducts.textContent = productLimit;
  selectedCount.textContent = selectedProducts.length;
  
  document.querySelectorAll('.ia-product-card').forEach(card => {
    const id = card.dataset.id;
    const isSelected = selectedProducts.includes(id);
    const isDisabled = !isSelected && selectedProducts.length >= productLimit;
    
    card.classList.toggle('selected', isSelected);
    card.classList.toggle('disabled', isDisabled);
  });
  
  if (selectedProducts.length === 0) {
    counterStatus.textContent = 'Select at least 1 product';
    counterStatus.className = 'ia-product-counter-limit warning';
  } else if (selectedProducts.length === productLimit) {
    counterStatus.textContent = `${selectedProducts.length} of ${productLimit} selected`;
    counterStatus.className = 'ia-product-counter-limit success';
  } else {
    counterStatus.textContent = `${selectedProducts.length} of ${productLimit} selected`;
    counterStatus.className = 'ia-product-counter-limit warning';
  }
}

// ── Step navigation ──
function setStep(n) {
  currentStep = n;
  document.querySelectorAll('.ia-step').forEach(s => s.classList.toggle('active', parseInt(s.dataset.step) === n));
  const stepEls = document.querySelectorAll('.ia-progress-step');
  const lineEls = document.querySelectorAll('.ia-progress-line');
  stepEls.forEach(s => {
    const i = parseInt(s.dataset.step);
    s.classList.toggle('active', i === n);
    s.classList.toggle('complete', i < n);
  });
  lineEls.forEach((l, idx) => l.classList.toggle('complete', idx + 1 < n));
  window.scrollTo({ top: document.getElementById('iaCard').offsetTop - 30, behavior: 'smooth' });
  
  // Load products when entering step 4
  if (n === 4 && availableProducts.length === 0) {
    loadProducts();
  }
}

document.querySelectorAll('[data-next]').forEach(btn => {
  btn.addEventListener('click', () => {
    const next = parseInt(btn.dataset.next);
    if (validateStep(currentStep)) setStep(next);
  });
});
document.querySelectorAll('[data-prev]').forEach(btn => {
  btn.addEventListener('click', () => setStep(parseInt(btn.dataset.prev)));
});

// ── Live uppercase + alphanumeric filter on the code field ──
const codeInput = document.getElementById('iaPreferredCode');
codeInput.addEventListener('input', () => {
  const filtered = codeInput.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
  if (filtered !== codeInput.value) codeInput.value = filtered;
});

// ── Follower count change listener ──
document.getElementById('iaFollowers').addEventListener('input', updateTierWidget);

// ── Validation ──
function setError(field, msg) {
  const inputId = 'ia' + field.charAt(0).toUpperCase() + field.slice(1);
  const errEl = document.querySelector(`[data-error-for="${field}"]`);
  const inp = document.getElementById(inputId);
  if (errEl) errEl.textContent = msg || '';
  if (inp) inp.classList.toggle('has-error', !!msg);
}
function clearAllErrors() {
  document.querySelectorAll('[data-error-for]').forEach(e => e.textContent = '');
  document.querySelectorAll('.has-error').forEach(e => e.classList.remove('has-error'));
}

function validateStep(step) {
  clearAllErrors();
  let ok = true;
  if (step === 1) {
    const name = document.getElementById('iaName').value.trim();
    const email = document.getElementById('iaEmail').value.trim();
    const phone = document.getElementById('iaPhone').value.replace(/\D/g, '');
    if (!name) { setError('name', 'Please enter your name'); ok = false; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setError('email', 'Please enter a valid email'); ok = false; }
    if (!phone || phone.length < 10) { setError('phone', 'Please enter a valid 10-digit number'); ok = false; }
  } else if (step === 2) {
    const ig = document.getElementById('iaInstagram').value.trim();
    const followers = document.getElementById('iaFollowers').value;
    const niche = document.getElementById('iaNiche').value;
    if (!ig) { setError('instagramHandle', 'Instagram handle is required'); ok = false; }
    if (!followers) { setError('followerCount', 'Follower count is required'); ok = false; }
    if (!niche) { setError('niche', 'Please select a niche'); ok = false; }
  } else if (step === 3) {
    const contentWeekly = document.getElementById('iaContentWeekly').value;
    const height = document.getElementById('iaHeight').value;
    const weight = document.getElementById('iaWeight').value;
    const address = document.getElementById('iaShippingAddress').value.trim();
    const city = document.getElementById('iaShippingCity').value.trim();
    const state = document.getElementById('iaShippingState').value;
    const pin = document.getElementById('iaShippingPin').value.trim();
    
    if (!contentWeekly || contentWeekly < 1) { setError('contentWeekly', 'Please enter content count'); ok = false; }
    if (!height || height < 100) { setError('heightCm', 'Please enter a valid height'); ok = false; }
    if (!weight || weight < 30) { setError('weightKg', 'Please enter a valid weight'); ok = false; }
    if (!address) { setError('shippingAddress', 'Shipping address is required'); ok = false; }
    if (!city) { setError('shippingCity', 'City is required'); ok = false; }
    if (!state) { setError('shippingState', 'Please select a state'); ok = false; }
    if (!pin || pin.length !== 6) { setError('shippingPin', 'Please enter a valid 6-digit PIN code'); ok = false; }
  } else if (step === 4) {
    if (selectedProducts.length === 0) { setError('selectedProducts', 'Please select at least 1 product'); ok = false; }
  } else if (step === 5) {
    const code = document.getElementById('iaPreferredCode').value.trim();
    const terms = document.getElementById('iaTerms').checked;
    if (!code || code.length < 4) { setError('preferredCode', 'Code must be at least 4 characters'); ok = false; }
    if (!terms) { setError('terms', 'Please accept the terms to continue'); ok = false; }
  }
  return ok;
}

// ── Map server error fields to form steps ──
const FIELD_TO_STEP = {
  name: 1, email: 1, phone: 1,
  instagramHandle: 2, followerCount: 2, niche: 2,
  contentWeekly: 3, heightCm: 3, weightKg: 3,
  shippingAddress: 3, shippingCity: 3, shippingState: 3, shippingPin: 3,
  selectedProducts: 4,
  preferredCode: 5, terms: 5
};

// ── Submit ──
document.getElementById('iaSubmitBtn').addEventListener('click', async () => {
  if (!validateStep(5)) return;

  const submitBtn = document.getElementById('iaSubmitBtn');
  submitBtn.disabled = true;
  submitBtn.textContent = 'Submitting…';

  const followerCount = parseInt(document.getElementById('iaFollowers').value) || 0;
  const tier = calculateFollowerTier(followerCount);

  const payload = {
    name: document.getElementById('iaName').value.trim(),
    email: document.getElementById('iaEmail').value.trim(),
    phone: document.getElementById('iaPhone').value.replace(/\D/g, ''),
    city: document.getElementById('iaCity').value.trim() || null,
    instagramHandle: document.getElementById('iaInstagram').value.trim(),
    youtubeHandle: document.getElementById('iaYoutube').value.trim() || null,
    followerCount: followerCount,
    followerTier: tier.tier,
    niche: document.getElementById('iaNiche').value || null,
    whyJoin: document.getElementById('iaWhyJoin').value.trim() || null,
    preferredCode: document.getElementById('iaPreferredCode').value.trim(),
    payoutUpi: document.getElementById('iaPayoutUpi').value.trim() || null,
    // New fields
    contentWeeklyCount: parseInt(document.getElementById('iaContentWeekly').value) || 3,
    heightCm: parseFloat(document.getElementById('iaHeight').value) || null,
    weightKg: parseFloat(document.getElementById('iaWeight').value) || null,
    shippingAddress: document.getElementById('iaShippingAddress').value.trim(),
    shippingCity: document.getElementById('iaShippingCity').value.trim(),
    shippingState: document.getElementById('iaShippingState').value,
    shippingPin: document.getElementById('iaShippingPin').value.trim(),
    shippingLandmark: document.getElementById('iaShippingLandmark').value.trim() || null,
    addressType: document.querySelector('input[name="addressType"]:checked')?.value || 'home',
    selectedProducts: selectedProducts
  };

  try {
    const res = await fetch(APPLY_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();

    if (!res.ok) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Application';
      const field = data.field;
      const msg = data.error || 'Something went wrong. Please try again.';
      if (field && FIELD_TO_STEP[field]) {
        setStep(FIELD_TO_STEP[field]);
        setError(field, msg);
      } else {
        alert(msg);
      }
      return;
    }

    // SUCCESS
    document.getElementById('iaCard').style.display = 'none';
    document.getElementById('iaResultCode').textContent = data.referralCode || '—';
    document.getElementById('iaResultUrl').textContent = data.portalUrl || '—';
    document.getElementById('iaSuccess').classList.add('show');
    window.scrollTo({ top: 0, behavior: 'smooth' });

  } catch (err) {
    console.error(err);
    submitBtn.disabled = false;
    submitBtn.textContent = 'Submit Application';
    alert('Network error. Please check your connection and try again.');
  }
});

// ── Copy portal URL ──
document.getElementById('iaCopyUrlBtn').addEventListener('click', async () => {
  const btn = document.getElementById('iaCopyUrlBtn');
  const url = document.getElementById('iaResultUrl').textContent;
  try {
    await navigator.clipboard.writeText(url);
    btn.textContent = 'Copied ✓';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.textContent = 'Copy';
      btn.classList.remove('copied');
    }, 2000);
  } catch (e) {
    alert('Could not copy. Please copy the URL manually.');
  }
});

// Initialize tier widget
updateTierWidget();
</script>

