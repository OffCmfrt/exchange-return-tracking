# Shopify Configuration
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_access_token_here
SHOPIFY_APP_SHARED_SECRET=your_app_shared_secret_here

# Shiprocket Configuration
