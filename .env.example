# Shopify Configuration
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_access_token_here
SHOPIFY_APP_SHARED_SECRET=your_app_shared_secret_here

# Shiprocket Configuration
SHIPROCKET_EMAIL=your_shiprocket_email@example.com
SHIPROCKET_PASSWORD=your_shiprocket_password

# Delhivery Configuration
DELHIVERY_API_KEY=your_delhivery_api_key_here
DELHIVERY_PICKUP_LOCATION=Primary

# Supabase Configuration
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_URL=https://your-project.supabase.co

# Server Configuration
PORT=3000

# WhatsApp Bot Integration
# URL of your existing WhatsApp bot server (the one running your confirmation/support bot)
WHATSAPP_BOT_URL=https://your-whatsapp-bot.example.com
# Shared secret token for authenticating internal calls between this server and the WA bot
WHATSAPP_INTERNAL_TOKEN=generate_a_long_random_string_here

# Meta WhatsApp Cloud API (Optional - for Marketing Dashboard)
# If not set, marketing messages will fallback to the WhatsApp bot above
META_ACCESS_TOKEN=your_meta_permanent_access_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_WABA_ID=your_waba_id_here
META_APP_SECRET=your_app_secret_here
META_VERIFY_TOKEN=your_webhook_verify_token_here

# Admin Authentication
ADMIN_PASSWORD=your_admin_password_here
